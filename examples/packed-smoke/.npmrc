# PR-D1 packed-smoke .npmrc.
#
# verify-deps-before-run=false — pnpm 11 added an auto-install
# check before `pnpm <script>` runs. For packed-smoke that auto-
# install would trigger on every invocation because the post-pack
# tarballs change content-hash each sync. The sync script already
# runs `pnpm install --force` explicitly, so the pre-run verify is
# redundant.
verify-deps-before-run=false
