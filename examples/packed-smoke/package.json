{
  "name": "packed-smoke",
  "version": "0.0.0",
  "private": true,
  "description": "PR-D1 (ADR-0082 follow-up): packed-copy consumer outside the pnpm workspace. Consumes @sophie/* via pnpm pack + file: tarball install — NOT via workspace links — so it surfaces packed-vs-workspace regressions (e.g. React #418 hydration mismatches) that the in-workspace smoke target cannot exercise by construction.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "type": "module",
  "scripts": {
    "sync": "bash scripts/sync-packed.sh",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.5",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@sophie/astro": "file:./vendor/sophie-astro-0.0.0.tgz",
    "@sophie/components": "file:./vendor/sophie-components-0.0.0.tgz",
    "@sophie/core": "file:./vendor/sophie-core-0.0.0.tgz",
    "@sophie/theme": "file:./vendor/sophie-theme-0.0.0.tgz",
    "astro": "^6.3.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@swc/core",
      "unrs-resolver"
    ]
  }
}
