vendor/*.tgz
node_modules/
dist/
.astro/
test-results/
playwright-report/

# Per-build lockfile. The tarballs in vendor/ are regenerated by
# scripts/sync-packed.sh on every install (locally + on CI). pnpm pack
# is NOT byte-deterministic — archive metadata (mtimes, gzip headers)
# varies run-to-run, so the lockfile's sha512 integrity hashes for the
# file:./vendor/*.tgz specs would drift on every regeneration. Source
# reproducibility comes from the workspace package contents + the pack
# process, not from pinning the tarball hashes; the lockfile is a
# disposable build artifact for this consumer. Same rationale as
# generated dist/ + .astro/ above.
pnpm-lock.yaml
