---
import { buildModuleNavInputs } from "@sophie/astro";
import CourseInferences from "@sophie/astro/components/CourseInferences.astro";
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";
import { figures as figureRegistry } from "../../content/figures";

const figureRegistryArray = Object.values(figureRegistry);

/**
 * `/library/inferences` — course-wide rollup of the `inference` slot of
 * every `<OMIFlow>` callsite across the textbook (Batch 5 / W4c Task 5.3).
 * Reads `omiFlows` via `indexAccumulator` inside `<CourseInferences>`;
 * sorted by unit slug → anchor; each entry back-links to its source unit
 * anchor. Mirrors the shape of `/library/observables` and
 * `/library/models` (the other two slots of the same OMI triad per
 * ADR 0058's eight-role contract).
 */

const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);
const { modules, chapters } = buildModuleNavInputs(sections, units);
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Inferences</title>
    <meta
      name='description'
      content='Course-wide rollup of the inference slot of every OMIFlow.'
    />
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <TextbookLayout figureRegistry={figureRegistryArray}>
        <Fragment slot='sidebar'>
          <ModuleNav modules={modules} chapters={chapters} />
        </Fragment>
        <CourseInferences heading='Inferences' />
      </TextbookLayout>
    </SophieChapter>
  </body>
</html>
