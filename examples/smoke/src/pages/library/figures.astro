---
import { buildModuleNavInputs } from "@sophie/astro";
import CourseFigures from "@sophie/astro/components/CourseFigures.astro";
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";
import { figures as figureRegistry } from "../../content/figures";

const figureRegistryArray = Object.values(figureRegistry);

/**
 * `/library/figures` — course-wide figure index auto-generated from the
 * pedagogy index (ADR 0038; PR-C3). Reads `figureUsages` +
 * `figureRegistry` via `indexAccumulator` inside `<CourseFigures>`;
 * chapter-order by default (per design decision #9: figure lookup is
 * topic/chapter-anchored, mirroring `/library/equations` and diverging from
 * `/library/glossary`'s alphabetical default); each figure appears once (the
 * canonical usage) and back-links to its canonical chapter anchor.
 * Mirrors the shape of `/library/equations`.
 */

// W2/D1 graduation: chapters + modules collections deleted; derive
// the ModuleNav input shape from units + sections via the shared
// helper (W4b R+CR I5 follow-up).
const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);
const { modules, chapters } = buildModuleNavInputs(sections, units);
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Figures</title>
    <meta
      name='description'
      content='Course-wide index of figures.'
    />
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <TextbookLayout figureRegistry={figureRegistryArray}>
        <Fragment slot='sidebar'>
          <ModuleNav modules={modules} chapters={chapters} />
        </Fragment>
        <CourseFigures heading='Figures (by chapter)' />
      </TextbookLayout>
    </SophieChapter>
  </body>
</html>
