---
import CourseMisconceptions from "@sophie/astro/components/CourseMisconceptions.astro";
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";
import { figures as figureRegistry } from "../content/figures";

const figureRegistryArray = Object.values(figureRegistry);

/**
 * `/misconceptions` — course-wide misconceptions index auto-generated
 * from the pedagogy index (ADR 0038; PR-C3). Reads `misconceptions`
 * via `indexAccumulator` inside `<CourseMisconceptions>`; chapter-order
 * by default (per design decision #9: misconception lookup is
 * reading-flow-anchored, mirroring `/equations` and `/figures`); each
 * entry back-links to its source `<Aside kind="misconception">` or
 * `<Callout variant="misconception">` in the source chapter. Length
 * discriminator visual class (decision #12) preserved.
 */

// W2/D1 graduation: chapters + modules collections deleted; derive
// the ModuleNav input shape from units + sections instead.
const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);
const modules = sections.map((s) => ({
  slug: s.slug,
  title: s.title,
  order: s.order,
  description: s.description,
}));
const chapters = units.map((u) => ({
  slug: u.id,
  title: u.title,
  module: u.section_id,
  order: u.order,
  chapter: undefined as number | undefined,
  status: u.status,
}));
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Common misconceptions</title>
    <meta
      name='description'
      content='Course-wide index of common misconceptions.'
    />
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <TextbookLayout figureRegistry={figureRegistryArray}>
        <Fragment slot='sidebar'>
          <ModuleNav modules={modules} chapters={chapters} />
        </Fragment>
        <CourseMisconceptions heading='Common misconceptions' />
      </TextbookLayout>
    </SophieChapter>
  </body>
</html>
