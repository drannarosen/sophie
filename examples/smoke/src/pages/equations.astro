---
import CourseEquations from "@sophie/astro/components/CourseEquations.astro";
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";

/**
 * `/equations` — course-wide equation index auto-generated from the
 * pedagogy index (ADR 0038; PR-C2). Reads `equations` via
 * `indexAccumulator` inside `<CourseEquations>`; chapter-order by
 * default (per design decision #7: equation lookup is
 * topic/chapter-anchored, diverging from glossary's alphabetical
 * default); each entry back-links to its source `<KeyEquation>` in
 * the source chapter. Mirrors the shape of `/glossary`.
 */

const modules = (await getCollection("modules")).map((m) => m.data);
const chapters = (await getCollection("chapters")).map((c) => ({
  slug: c.id,
  title: c.data.title,
  module: c.data.module,
  order: c.data.order,
}));
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Equations</title>
    <meta
      name='description'
      content='Course-wide index of key equations.'
    />
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <TextbookLayout>
        <Fragment slot='sidebar'>
          <ModuleNav modules={modules} chapters={chapters} />
        </Fragment>
        <CourseEquations heading='Key equations (by chapter)' />
      </TextbookLayout>
    </SophieChapter>
  </body>
</html>
