---
import { makeStaticComponents } from "@sophie/astro";
import { getCollection, render } from "astro:content";
import { figures } from "../../../content/figures";
import ChapterLayout from "../../../layouts/ChapterLayout.astro";

// Module-level singleton: every chapter in this smoke target shares the
// same figure registry, so the components map is built once instead of
// per-render.
const components = makeStaticComponents({ figures });

export async function getStaticPaths() {
  // W2/D1 (Path A) + D5: routes for every reading-artifact in the
  // artifacts collection. ADR 0051 graduates per W2/D2 — drafts now
  // live on UnitEntry.status; filter the route-set against the units
  // collection so draft units don't render student-facing routes.
  const artifacts = await getCollection("artifacts");
  const units = await getCollection("units");
  const draftUnitIds = new Set(
    units.filter((u) => u.data.status === "draft").map((u) => u.data.id),
  );
  const readings = artifacts.filter(
    (a) =>
      a.id.endsWith("/reading") &&
      // Path-derived unit id is path-position-2 (sections/<sec>/units/<unit>/reading).
      !draftUnitIds.has(a.id.split("/")[2] ?? ""),
  );
  return readings.map((artifact) => {
    const unitId = artifact.id.split("/")[2] ?? "";
    return { params: { unit: unitId }, props: { artifact } };
  });
}

const { artifact } = Astro.props;
const { Content, headings } = await render(artifact);
---

<ChapterLayout
  frontmatter={artifact.data}
  currentChapterSlug={artifact.data.id}
  headings={headings}
>
  <Content components={components} />
</ChapterLayout>
