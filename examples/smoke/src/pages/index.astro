---
import { getCollection } from "astro:content";

// W2/D1 (Path A) per ADR 0067: list units (was chapters) and link to
// their /units/<unit-id>/reading routes.
const units = await getCollection("units");
units.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sophie — Phase 0 smoke target</title>
  </head>
  <body>
    <main>
      <h1>Sophie — Phase 0 smoke target</h1>
      <p>
        Throwaway. Renders the trimmed first ASTR 201 reading through every
        <code>@sophie/*</code> package to prove the slice end-to-end.
      </p>
      <h2>Chapters</h2>
      <ul>
        {
          units.map((u) => (
            <li>
              <a href={`/units/${u.data.id}/reading`}>{u.data.title}</a>
              {u.data.description && <p>{u.data.description}</p>}
            </li>
          ))
        }
      </ul>
      <h2>Library</h2>
      <p>
        <a href='/library/'>Library</a> — course-wide reference rooms
        (glossary, equations, figures, key insights, misconceptions,
        objectives).
      </p>
    </main>
  </body>
</html>
