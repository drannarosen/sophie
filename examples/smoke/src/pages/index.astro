---
import { getCollection } from "astro:content";

const chapters = await getCollection("chapters");
chapters.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sophie — Phase 0 smoke target</title>
  </head>
  <body>
    <main>
      <h1>Sophie — Phase 0 smoke target</h1>
      <p>
        Throwaway. Renders the trimmed first ASTR 201 reading through every
        <code>@sophie/*</code> package to prove the slice end-to-end.
      </p>
      <h2>Chapters</h2>
      <ul>
        {
          chapters.map((c) => (
            <li>
              <a href={`/chapters/${c.id}`}>{c.data.title}</a>
              {c.data.description && <p>{c.data.description}</p>}
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
