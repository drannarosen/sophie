---
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import TocDrawer from "@sophie/astro/components/TocDrawer.astro";
import TocSidebar from "@sophie/astro/components/TocSidebar.astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";
import type { MarkdownHeading } from "astro";
import { figures as figureRegistry } from "../content/figures";

// Convert the consumer-owned figures registry (a named-keyed map; see
// `src/content/figures.ts`) into the array shape `<TextbookLayout>`
// expects so `<FigureRef>` can hydrate its registry store on every page.
// PR-C3 decision #3 + Task 12 wiring.
const figureRegistryArray = Object.values(figureRegistry);

interface Props {
  frontmatter: {
    title: string;
    slug: string;
    module: string;
    order?: number;
    lang?: string;
    description?: string;
  };
  /** Astro collection id of the chapter currently being rendered. */
  currentChapterSlug?: string;
  /** Chapter headings (h1-h6) extracted by Astro's render(). */
  headings?: ReadonlyArray<MarkdownHeading>;
}

const { frontmatter, currentChapterSlug, headings = [] } = Astro.props;

// Only populate the right-column slot when the chapter has H2 headings.
// `<TocSidebar>` returns null otherwise, but `Astro.slots.has("right")`
// would still see a populated slot — defeating the empty-slot-collapse
// pattern in <TextbookLayout> (ADR 0034). Filter here so stub chapters
// (no H2s) genuinely leave the slot empty and the column collapses.
const hasToc = headings.some((h) => h.depth === 2);

// Fetch every module + chapter from the content collections so the
// sidebar nav can render the full tree on every chapter page. The
// glob loader is cached by Astro across requests; no perf concern.
const modules = (await getCollection("modules")).map((m) => m.data);
const chapters = (await getCollection("chapters")).map((c) => ({
  slug: c.id,
  title: c.data.title,
  module: c.data.module,
  order: c.data.order,
}));
---

<html lang={frontmatter.lang ?? "en"}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{frontmatter.title}</title>
    {
      frontmatter.description && (
        <meta name='description' content={frontmatter.description} />
      )
    }
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <TextbookLayout figureRegistry={figureRegistryArray}>
        <Fragment slot='sidebar'>
          <ModuleNav
            modules={modules}
            chapters={chapters}
            currentChapterSlug={currentChapterSlug}
          />
        </Fragment>
        {
          hasToc && (
            <Fragment slot='right'>
              <TocSidebar headings={headings} />
            </Fragment>
          )
        }
        <h1>{frontmatter.title}</h1>
        <slot />
      </TextbookLayout>
      <TocDrawer headings={headings} />
    </SophieChapter>
  </body>
</html>
