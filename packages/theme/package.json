{
  "name": "@sophie/theme",
  "version": "0.0.0",
  "description": "Sophie design tokens — TS-canonical role tree + light/dark CSS variables + Tailwind v4 @theme emit.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./css": "./dist/theme.css",
    "./base": "./dist/base.css",
    "./fonts": "./dist/fonts.css",
    "./math": "./dist/math.css",
    "./tailwind": "./dist/tailwind.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7"
  }
}
