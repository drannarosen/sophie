{
  "name": "@sophie/figures-kit",
  "version": "0.0.0",
  "description": "Sophie's universal interactive-figure chrome kit — modular primitives (Figure, FigureTitle, FigureBody, FigureControls, FigurePanel, FigureAside, FigureFooter, FigureCaption, Readout, ValidityToggle, ResetButton, ParameterScrub, ColorSwatch, InlineMath) + cross-figure helpers. Backend-agnostic; wraps Plot, R3F, React Flow, iframe, or any other inner renderer.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "dependencies": {
    "@sophie/components": "workspace:*",
    "@sophie/core": "workspace:*",
    "@sophie/theme": "workspace:*",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "postcss-modules": "^6.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
