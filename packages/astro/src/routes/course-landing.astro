---
import {
  HeroWithModules,
  ProseWithToc,
  SimpleList,
} from "@sophie/components";
import { getCollection } from "astro:content";
import { courseSpec } from "virtual:sophie/course-spec";
import InfoPageShell from "../components/InfoPageShell.astro";

/**
 * Course landing dispatcher. Pattern: `/`. Injected by
 * defineSophieIntegration when course.sophie.yaml is present.
 *
 * Reads `landing.layout` from the spec to pick one of the three
 * built-in layouts (`simple-list`, `hero-with-modules`,
 * `prose-with-toc`). When `"custom"` is declared, the consumer must
 * shadow this route with their own `src/pages/index.astro` (per
 * H2/B4 — schema is the declarative locus; the override path was
 * future-proofed in landing-schema). v0.2 ships SimpleList as the
 * real implementation; the other two delegate to it pending follow-up
 * sprints.
 */
// Defensive null guard — runtime-unreachable today because the
// integration only injects `/` when courseSpec is non-null, but
// declaring the invariant at the route boundary documents the
// contract + narrows the type from `CourseSpec | null` (per the
// virtual module's always-register signature). Per Phase 1-4
// review C1.
if (!courseSpec) {
  throw new Error(
    "[sophie] course-landing.astro: virtual:sophie/course-spec exported null. " +
      "This route should only be injected when course.sophie.yaml is present. " +
      "Check the integration's injectRoute guard."
  );
}

const layoutKey = courseSpec.landing?.layout ?? "simple-list";

if (layoutKey === "custom") {
  throw new Error(
    "[sophie] landing.layout: 'custom' requires a consumer-shadow at src/pages/index.astro. " +
      "Either author the override file or change landing.layout to one of: simple-list, hero-with-modules, prose-with-toc."
  );
}

// Sections + units shape the unit-list rendering; the layout filters
// (draft units) + sorts (by `order`) internally.
const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);
---

{/*
  InfoPageShell supplies the document chrome (<html>/<head> with
  charset + viewport + title + stylesheet); the landing layout renders
  its own <main> into the slot. Without the shell the page emits a bare
  <main> with no <head>, so Astro has nowhere to inject the layout CSS
  and the browser mis-decodes UTF-8 (no charset).

  Explicit per-layout dispatch (mirrors info-page.astro). The landing
  layouts are static presentational components — no client:load. A
  dynamically-selected component variable (`<Layout client:.../>`)
  cannot be statically resolved by Astro's hydration-script generator
  ("No matching import has been found for `Layout`"), so each layout
  is rendered by an explicit conditional instead.
*/}
<InfoPageShell
  title={`${courseSpec.identity.code} — ${courseSpec.identity.title}`}
  description={courseSpec.identity.description}
>
  {layoutKey === "simple-list" && (
    <SimpleList spec={courseSpec} sections={sections} units={units} />
  )}
  {layoutKey === "hero-with-modules" && (
    <HeroWithModules spec={courseSpec} sections={sections} units={units} />
  )}
  {layoutKey === "prose-with-toc" && (
    <ProseWithToc spec={courseSpec} sections={sections} units={units} />
  )}
</InfoPageShell>
