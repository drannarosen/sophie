---
import { ProseWithToc, SimpleList } from "@sophie/components";
import { setSophieBaseUrl } from "@sophie/core/runtime";
import { getCollection } from "astro:content";
import { assignments } from "virtual:sophie/assignments";
import { courseSpec } from "virtual:sophie/course-spec";
import { schedule } from "virtual:sophie/schedule";
import CourseHomeShell from "../components/course-home/CourseHomeShell.astro";
import {
  dueSoon,
  startReading,
} from "../components/course-home/home-card-projections";
import {
  howBand,
  whyBand,
} from "../components/course-home/home-projections";
import {
  scheduleRows,
  thisWeek,
} from "../components/course-home/home-schedule-projections";
import InfoPageShell from "../components/InfoPageShell.astro";

// Feed the consumer's Vite-replaced base to the externalized-in-Node
// SSR/prerender dist of @sophie/* (where import.meta.env is undefined).
// See withBase + @sophie/core/runtime base-url store. ADR 0092.
setSophieBaseUrl(import.meta.env.BASE_URL);

/**
 * Course landing dispatcher. Pattern: `/`. Injected by
 * defineSophieIntegration when course.sophie.yaml is present.
 *
 * Reads `landing.layout` from the spec to pick a built-in layout:
 * `"dashboard"` (and its `"hero-with-modules"` alias, ADR 0097 #1) →
 * the <CourseHomeShell> Deep Field dashboard; `"simple-list"` /
 * `"prose-with-toc"` → the lighter @sophie/components layouts. When
 * `"custom"` is declared, the consumer must shadow this route with
 * their own `src/pages/index.astro` (per H2/B4 — schema is the
 * declarative locus; the override path was future-proofed in
 * landing-schema).
 *
 * SHELL OWNERSHIP (ADR 0097 #2): <CourseHomeShell> renders the WHOLE
 * document (`<html>/<head>` via shared <SophieHead> + <HomeBackground>
 * + <body>), so the dashboard branch is NOT wrapped in <InfoPageShell>;
 * the simple-list / prose-with-toc layouts render only a `<main>` and
 * still mount inside <InfoPageShell> for the document chrome.
 */
// Defensive null guard — runtime-unreachable today because the
// integration only injects `/` when courseSpec is non-null, but
// declaring the invariant at the route boundary documents the
// contract + narrows the type from `CourseSpec | null` (per the
// virtual module's always-register signature). Per Phase 1-4
// review C1.
if (!courseSpec) {
  throw new Error(
    "[sophie] course-landing.astro: virtual:sophie/course-spec exported null. " +
      "This route should only be injected when course.sophie.yaml is present. " +
      "Check the integration's injectRoute guard."
  );
}

const layoutKey = courseSpec.landing?.layout ?? "simple-list";

if (layoutKey === "custom") {
  throw new Error(
    "[sophie] landing.layout: 'custom' requires a consumer-shadow at src/pages/index.astro. " +
      "Either author the override file or change landing.layout to one of: dashboard, hero-with-modules, simple-list, prose-with-toc."
  );
}

// `dashboard` is canonical; `hero-with-modules` is its documented alias
// (ADR 0097 #1). Both resolve to <CourseHomeShell>.
const isDashboard =
  layoutKey === "dashboard" || layoutKey === "hero-with-modules";

// Sections + units shape the unit-list rendering; the layout filters
// (draft units) + sorts (by `order`) internally.
const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);

// ── Dashboard projections (ADR 0097 #2/#3/#7; ADR 0098) ────────────
// Single build wall-clock read for the calendar-aware Due-Soon card +
// the schedule-derived week-ranges / "Now" marker / This-Week card.
// Build-time-only `new Date()` (no workflow script; mirrors
// solutions.astro's one wall-clock read) → injected into the pure
// `dueSoon` / `scheduleRows` / `thisWeek` projections so the date logic
// stays testable.
//
// `assignments` (virtual:sophie/assignments, AssignmentRegistry | null) and
// `schedule` (virtual:sophie/schedule, Schedule | null) are OPTIONAL —
// NOT R12-narrowed: the Due-Soon / week-range / This-Week surfaces degrade
// to nothing when null (ADR 0097 #7). Each projection null-guards its
// argument internally, and no direct property access happens here, so no
// narrowing throw is needed (R12 scopes to course-spec, which IS narrowed
// above; `assignments` + `schedule` are documented exceptions — the
// homework precedent for null-safe optional projections, ADR 0096).
const now = new Date();
const dueSoonItems = isDashboard
  ? dueSoon(assignments, now, undefined, courseSpec.assignment_kinds ?? {})
  : [];
const scheduleRowData = isDashboard
  ? scheduleRows(schedule, sections, units, now)
  : [];
const thisWeekItems = isDashboard ? thisWeek(schedule, assignments, now) : [];
const startReadingLink = isDashboard ? startReading(units) : undefined;
const why = isDashboard
  ? whyBand(courseSpec.identity.description, courseSpec.pedagogy.named_tools)
  : undefined;
const how = isDashboard
  ? howBand(
      courseSpec.pedagogy.required_moves,
      courseSpec.pedagogy.multi_track_readings
    )
  : undefined;
const tagline =
  courseSpec.landing?.hero?.tagline ?? courseSpec.identity.subtitle;
---

{/*
  InfoPageShell supplies the document chrome (<html>/<head> with
  charset + viewport + title + stylesheet); the landing layout renders
  its own <main> into the slot. Without the shell the page emits a bare
  <main> with no <head>, so Astro has nowhere to inject the layout CSS
  and the browser mis-decodes UTF-8 (no charset).

  Explicit per-layout dispatch (mirrors info-page.astro). The landing
  layouts are static presentational components — no client:load. A
  dynamically-selected component variable (`<Layout client:.../>`)
  cannot be statically resolved by Astro's hydration-script generator
  ("No matching import has been found for `Layout`"), so each layout
  is rendered by an explicit conditional instead.
*/}
{
  isDashboard ? (
    <CourseHomeShell
      code={courseSpec.identity.code}
      title={courseSpec.identity.title}
      tagline={tagline}
      instructor={courseSpec.identity.instructor}
      institution={courseSpec.identity.institution}
      term={courseSpec.identity.term}
      sections={sections}
      units={units}
      infoPages={courseSpec.info_pages}
      why={why}
      how={how}
      dueSoon={dueSoonItems}
      scheduleRows={scheduleRowData}
      thisWeek={thisWeekItems}
      startReading={startReadingLink}
    />
  ) : (
    <InfoPageShell
      title={`${courseSpec.identity.code} — ${courseSpec.identity.title}`}
      description={courseSpec.identity.description}
    >
      {layoutKey === "simple-list" && (
        <SimpleList spec={courseSpec} sections={sections} units={units} />
      )}
      {layoutKey === "prose-with-toc" && (
        <ProseWithToc spec={courseSpec} sections={sections} units={units} />
      )}
    </InfoPageShell>
  )
}
