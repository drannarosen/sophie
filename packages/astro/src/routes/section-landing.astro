---
import { SectionLanding } from "@sophie/components";
import { setSophieBaseUrl } from "@sophie/core/runtime";
import { getCollection } from "astro:content";
import { courseSpec } from "virtual:sophie/course-spec";
import HomeBackground from "../components/backgrounds/HomeBackground.astro";
import InfoPageShell from "../components/InfoPageShell.astro";

// Feed the consumer's Vite-replaced base to the externalized-in-Node
// SSR/prerender dist of @sophie/* (where import.meta.env is undefined).
// See withBase + @sophie/core/runtime base-url store. ADR 0092.
setSophieBaseUrl(import.meta.env.BASE_URL);

/**
 * Section landing route. Pattern: `/sections/[section]/`. Injected by
 * defineSophieIntegration when course.sophie.yaml is present.
 *
 * Standard getStaticPaths shape — one route per section in the
 * content collection. Filters units by `section_id === section.slug`
 * and passes them to the layout, which handles draft-status
 * filtering + order sorting + the visual shell.
 *
 * Renders inside <InfoPageShell> (same shell as course-landing) so the
 * section spine gets the shared <SophieHead> — global CSS + a real
 * `<title>` — instead of the bare unstyled, empty-titled component it
 * was before (astr201 review F1/F2 / B1/B2; ADR 0095).
 */
export async function getStaticPaths() {
  const sections = (await getCollection("sections")).map((s) => s.data);
  const units = (await getCollection("units")).map((u) => u.data);
  return sections.map((section) => ({
    params: { section: section.slug },
    props: { section, units },
  }));
}

// Defensive null guard — runtime-unreachable today (integration
// only injects /sections/[section]/ when courseSpec is non-null),
// but documents the invariant at the route boundary. Per Phase 1-4
// review C1.
if (!courseSpec) {
  throw new Error(
    "[sophie] section-landing.astro: virtual:sophie/course-spec exported null. " +
      "This route should only be injected when course.sophie.yaml is present. " +
      "Check the integration's injectRoute guard."
  );
}

const { section, units } = Astro.props;
---

{/*
  Section landings share the course home's Deep Field background (ADR
  0097 #5 scope = home + section landings only; reading/practice/
  solutions routes do NOT get it). <HomeBackground>'s layers are
  `position: fixed` (z-index −2/−3 + a no-JS `.sky` fallback), so it
  sits beneath the <SectionLanding> content with no layout change.
*/}
<InfoPageShell title={`${section.title} — ${courseSpec.identity.title}`}>
  <HomeBackground />
  <SectionLanding
    client:load
    spec={courseSpec}
    section={section}
    units={units}
  />
</InfoPageShell>
