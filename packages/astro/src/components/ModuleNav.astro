---
import { chaptersForModule } from "@sophie/core/schema";
import type { NavChapter, NavModule } from "../lib/module-nav-helpers";
import { withBase } from "../lib/with-base";

/**
 * <ModuleNav> — sidebar module/chapter tree.
 *
 * Pure Astro; no React. SSR-renders the full module/chapter
 * structure with `aria-current="page"` on the active chapter
 * link. CSS targets `[aria-current="page"]` for the highlight;
 * no client JS.
 *
 * Per PR 3 design doc (docs/plans/2026-05-12-sidebar-module-nav-design.md).
 * Lives in the sidebar slot of <TextbookLayout>. When the slot is
 * filled, the empty-slot-collapse logic (ADR 0034) lets the column
 * expand to its default width.
 *
 * `NavChapter` and `NavModule` are canonical in
 * `../lib/module-nav-helpers.ts` (R9-production: one declaration
 * per named interface).
 */

interface Props {
  modules: ReadonlyArray<NavModule>;
  chapters: ReadonlyArray<NavChapter>;
  /** Set to the current chapter's slug for active-state highlight. */
  currentChapterSlug?: string;
}

const { modules, chapters, currentChapterSlug } = Astro.props;
const sortedModules = [...modules].sort((a, b) => a.order - b.order);
---

<nav class='sophie-module-nav' aria-label='Chapters'>
  <ol class='sophie-module-list'>
    {
      sortedModules.map((m) => {
        const moduleChapters = chaptersForModule(m.slug, chapters);
        const containsCurrent = moduleChapters.some(
          (c) => c.slug === currentChapterSlug
        );
        return (
          <li class='sophie-module' data-module={m.slug}>
            <details
              class='sophie-module-disclosure'
              open={containsCurrent || currentChapterSlug === undefined}
            >
              <summary class='sophie-module-title'>
                <span class='sophie-module-title__label'>{m.title}</span>
                <span class='sophie-module-title__chevron' aria-hidden='true' />
              </summary>
              <ol class='sophie-chapter-list'>
                {moduleChapters.map((c) => (
                  <li>
                    <a
                      href={withBase(`/units/${c.slug}/reading`)}
                      aria-current={
                        c.slug === currentChapterSlug ? "page" : undefined
                      }
                    >
                      {c.title}
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          </li>
        );
      })
    }
  </ol>
  {/* "Made with Sophie" attribution moved to the right column's
      footer (RightColumn.astro) in the 2026-05-21 polish pass —
      MyST-style margin wordmark with a brand-teal accent on "Sophie".
      Left sidebar stays focused on chapter nav only. */}
</nav>
