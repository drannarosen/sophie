---
import type { KeyInsightEntry } from "@sophie/core/schema";
import { indexAccumulator } from "../lib/pedagogy-index-extractor";

const { keyInsights } = indexAccumulator.asPedagogyIndex();

/**
 * `<ChapterKeyInsights chapter="..." heading="..." />` — Astro consumer
 * of the build-time pedagogy index (ADR 0038). Renders one chapter's
 * key-insight asides as a `<dl>`.
 *
 * Sort: appearance order only (PR-C3 design decision #7). Key-insights
 * have OPTIONAL titles, so alphabetical sort doesn't fit untitled
 * entries — no `order` prop. Entries are emitted by the extractor in
 * source-walk order, so the filtered slice preserves that order.
 *
 * Bodies are pre-rendered HTML embedded via `set:html`. Pure Astro;
 * no client JS. Reads the accumulator directly per ADR 0038's
 * Revisions section (virtual-module bypass; mirrors
 * `<ChapterEquations>` / `<ChapterGlossary>`).
 */
export interface Props {
  /** Chapter slug to filter the index by (e.g. "spoiler-alerts"). */
  chapter: string;
  /** Optional heading rendered above the list. */
  heading?: string;
}

const { chapter, heading } = Astro.props;

const inChapter: KeyInsightEntry[] = keyInsights.filter(
  (k) => k.chapter === chapter
);
// Appearance-order sort: entries are already in source-walk order; no resort.
---

{heading && <h2 class='sophie-chapter-key-insights__heading'>{heading}</h2>}
{
  inChapter.length === 0 ? (
    <p class='sophie-chapter-key-insights__empty'>
      No key insights in this chapter yet.
    </p>
  ) : (
    <dl
      class='sophie-chapter-key-insights'
      data-sophie-chapter-key-insights=''
    >
      {inChapter.map((entry) => (
        <Fragment>
          <dt
            id={`ki-${entry.anchor}`}
            class='sophie-chapter-key-insights__term'
          >
            {entry.title ?? "Key insight"}
          </dt>
          <dd
            class='sophie-chapter-key-insights__body'
            set:html={entry.body}
          />
        </Fragment>
      ))}
    </dl>
  )
}
