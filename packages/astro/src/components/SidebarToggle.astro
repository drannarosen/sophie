---
/**
 * <SidebarToggle> — accessible toggle button for the sidebar's
 * open/closed state. State lives in `data-sidebar` on <html>; this
 * button flips it and persists to localStorage.
 *
 * The boot script (in <TextbookLayout>) sets the initial state from
 * localStorage *before paint* to prevent FOUC. This component's
 * inline script wires the click handler + cross-tab `storage` event.
 *
 * No React; ~20 LOC of vanilla JS total. Per
 * docs/plans/2026-05-12-layout-shell-foundation-design.md Q3.
 */
---

<button
  type='button'
  class='sophie-sidebar-toggle'
  data-sophie-sidebar-toggle
  aria-controls='sophie-sidebar-region'
  aria-expanded='true'
  aria-label='Toggle sidebar'
>
  <svg
    width='20'
    height='20'
    viewBox='0 0 20 20'
    fill='none'
    aria-hidden='true'
    focusable='false'
  >
    <path
      d='M3 5h14M3 10h14M3 15h14'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
    />
  </svg>
</button>

<script>
  // Click handler + cross-tab storage sync.
  // Idempotent: safe to load multiple times (buttons are queried fresh
  // each time and listeners are attached only to elements that lack
  // our marker attribute).
  (function () {
    const STORAGE_KEY = "sophie:sidebar";
    const ATTR = "data-sidebar";
    const html = document.documentElement;

    function setState(next: "open" | "closed", persist: boolean) {
      html.setAttribute(ATTR, next);
      document.querySelectorAll<HTMLButtonElement>(
        "[data-sophie-sidebar-toggle]",
      ).forEach((btn) => {
        btn.setAttribute("aria-expanded", next === "open" ? "true" : "false");
      });
      if (persist) {
        try {
          localStorage.setItem(STORAGE_KEY, next);
        } catch {
          // localStorage may be disabled (Safari private mode); fail silently.
        }
      }
    }

    document.querySelectorAll<HTMLButtonElement>(
      "[data-sophie-sidebar-toggle]:not([data-sophie-bound])",
    ).forEach((btn) => {
      btn.setAttribute("data-sophie-bound", "true");
      btn.addEventListener("click", () => {
        const current = html.getAttribute(ATTR) === "closed" ? "closed" : "open";
        setState(current === "open" ? "closed" : "open", true);
      });
    });

    // Cross-tab sync: listen once.
    if (!(window as Window & { __sophieSidebarStorageBound?: boolean })
      .__sophieSidebarStorageBound) {
      (window as Window & { __sophieSidebarStorageBound?: boolean })
        .__sophieSidebarStorageBound = true;
      window.addEventListener("storage", (event) => {
        if (event.key !== STORAGE_KEY) return;
        const incoming = event.newValue === "closed" ? "closed" : "open";
        setState(incoming, false);
      });
    }
  })();
</script>
