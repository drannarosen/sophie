---
import { Menu } from "../icons";

/**
 * <SidebarToggle> — accessible toggle button for the sidebar's
 * open/closed state. Drives `data-sidebar` on <html> through the
 * generic `sidebarPref` (preferences/sidebar.ts), which encapsulates
 * the localStorage round-trip, cross-tab `storage` event sync, and
 * idempotent click binding.
 *
 * Pre-paint state is set by the boot script in <TextbookHead>; this
 * component just wires interaction.
 *
 * Icon: Lucide `Menu` via lucide-static (no React) — per the
 * two-adapter icon convention introduced in this PR's design doc.
 */
---

<button
  type='button'
  class='sophie-sidebar-toggle'
  data-sophie-sidebar-toggle
  aria-controls='sophie-sidebar-region'
  aria-expanded='true'
  aria-label='Toggle sidebar'
>
  <Fragment set:html={Menu} />
</button>

<script>
  import { sidebarPref } from "../preferences";

  function syncAriaExpanded(next: "open" | "closed"): void {
    document
      .querySelectorAll<HTMLButtonElement>("[data-sophie-sidebar-toggle]")
      .forEach((btn) => {
        btn.setAttribute(
          "aria-expanded",
          next === "open" ? "true" : "false",
        );
      });
  }

  syncAriaExpanded(sidebarPref.read());
  sidebarPref.subscribe(syncAriaExpanded);

  document
    .querySelectorAll<HTMLButtonElement>("[data-sophie-sidebar-toggle]")
    .forEach((btn) => {
      sidebarPref.bindToggle(btn, (cur) =>
        cur === "open" ? "closed" : "open",
      );
    });
</script>
