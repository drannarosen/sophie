---
/**
 * <WhyBand /> — the "Why this course is different" descriptive band (ADR
 * 0097 #3). A Fraunces lead line + a grid of pillars over the Deep Field
 * ground, ported from the prototype's `.prose-band` / `.why-grid`.
 *
 * Chrome (role-less, ADR 0058): a course-spec PROJECTION of the `identity`
 * + `pedagogy` clusters, NOT a pedagogy primitive. It carries no
 * epistemicRole, never enters the pedagogy index / Library, and is wired
 * via the chrome path (it lives in @sophie/astro, outside the R13 gate's
 * `packages/components` scope — a documentary CHROME allowlist entry
 * mirrors the sibling pieces).
 *
 * PROJECTED vs FIXED EDITORIAL (honest accounting per ADR 0097 #3 + W1):
 *   - `lead`            PROJECTED  — first sentence of identity.description
 *                                    (`whyLead`). Absent → no lead line.
 *   - "toolkit" pillar  PROJECTED  — body is the named_tools list
 *                                    (`toolkitPillarBody`). No tools →
 *                                    the pillar is dropped upstream.
 *   - the other pillars FIXED      — editorial distillations of the OMI
 *                                    pattern (heading + minimal body) that
 *                                    no single spec field derives.
 * The projection itself lives in `home-projections.ts` (`whyBand`); this
 * piece is presentational and renders whatever it's handed.
 *
 * GRACEFUL DEGRADATION (ADR 0097 #7): an absent `lead` omits the lead
 * paragraph; the upstream projection drops the toolkit pillar when no
 * tools are declared. The band always carries ≥2 fixed pillars, so it
 * never renders an empty shell.
 *
 * LANDMARK (R10): a `<section aria-labelledby>` named region nested under
 * the shell's single `<main>` — never a second `<main>`.
 */
import type { WhyPillar } from "./home-projections";

interface Props {
  /** Projected lead clause from identity.description; absent → no lead. */
  lead?: string;
  /** The Why-pillars (≥2 fixed + optional projected toolkit). */
  pillars: ReadonlyArray<WhyPillar>;
}

const { lead, pillars } = Astro.props;
const headingId = "sophie-home-why-heading";
---

<section class='sophie-home-why' aria-labelledby={headingId}>
  <h2 id={headingId} class='sophie-home-why__label'>
    Why this course is different
  </h2>
  {lead && <p class='sophie-home-why__lead'>{lead}</p>}
  <div class='sophie-home-why__grid'>
    {
      pillars.map((pillar) => (
        <div class='sophie-home-why__pillar'>
          <span class='sophie-home-why__ic' aria-hidden='true'>
            {pillar.glyph}
          </span>
          <h3 class='sophie-home-why__heading'>{pillar.heading}</h3>
          <p class='sophie-home-why__body'>{pillar.body}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .sophie-home-why {
    margin-top: clamp(3rem, 7vw, 5rem);
  }
  .sophie-home-why__label {
    font-family: var(--sophie-font-mono);
    font-weight: 500;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--sophie-home-ink-muted);
    margin: 0 0 1.2rem;
  }
  .sophie-home-why__lead {
    font-family: var(--sophie-font-serif);
    font-weight: 400;
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--sophie-home-ink);
    max-width: 30ch;
    margin: 0 0 2.4rem;
  }
  .sophie-home-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.7rem;
  }
  .sophie-home-why__ic {
    color: var(--sophie-home-teal);
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.55rem;
  }
  .sophie-home-why__heading {
    font-family: var(--sophie-font-serif);
    font-weight: 500;
    font-size: 1.18rem;
    margin: 0 0 0.4rem;
    color: var(--sophie-home-ink);
  }
  .sophie-home-why__body {
    margin: 0;
    color: var(--sophie-home-ink-soft);
    font-size: 0.97rem;
    line-height: 1.55;
  }
  @media (max-width: 820px) {
    .sophie-home-why__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
