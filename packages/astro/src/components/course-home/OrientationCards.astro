---
/**
 * <OrientationCards /> — the three-card orientation row (ADR 0097 #2/#7):
 * "This Week" · "Due Soon" · "Start Reading". This task (Task 3) ships
 * the LAYOUT + card chrome only; the card BODIES are named slots with
 * static placeholder fallbacks.
 *
 * Chrome (role-less, ADR 0058): calendar-aware orientation, not pedagogy.
 *
 * SEAM FOR TASK 6 (data wiring + graceful degradation, ADR 0097 #7):
 *   - slot `this-week`   — schedule-derived (ADR 0098, PR 2). When the
 *                          schedule virtual module is null the caller
 *                          renders NOTHING into this slot AND should drop
 *                          the card (fail-closed); until then the static
 *                          fallback shows the card shape.
 *   - slot `due-soon`    — live from the homework registry (ADR 0096) in
 *                          Task 6.
 *   - slot `start-reading` — first/next non-draft unit; always resolvable.
 *
 * Card visibility is the caller's concern (Task 6 decides which cards to
 * render given null schedule/announcements). This component owns the grid
 * + card styling; it renders whatever slots it is handed, falling back to
 * representative placeholders so the layout is reviewable now.
 */
const labelId = "sophie-home-cards-heading";
---

<section class='sophie-home-cards' aria-labelledby={labelId}>
  <h2 id={labelId} class='sophie-home-cards__sr-heading'>Course orientation</h2>

  <div class='sophie-home-card'>
    <p class='sophie-home-card__label'>
      <span class='sophie-home-card__ic' aria-hidden='true'>◷</span> This Week
    </p>
    <slot name='this-week'>
      <p class='sophie-home-card__big'>Week 1</p>
      <p class='sophie-home-card__meta'>Foundations — first lecture</p>
    </slot>
  </div>

  <div class='sophie-home-card'>
    <p class='sophie-home-card__label'>
      <span class='sophie-home-card__ic' aria-hidden='true'>◆</span> Due Soon
    </p>
    <slot name='due-soon'>
      <div class='sophie-home-due'>
        <span class='sophie-home-due__dot sophie-home-due__dot--soon'></span>
        Homework 1 <span class='sophie-home-due__when'>tbd</span>
      </div>
    </slot>
  </div>

  <div class='sophie-home-card'>
    <p class='sophie-home-card__label'>
      <span class='sophie-home-card__ic' aria-hidden='true'>▸</span> Start
      Reading
    </p>
    <slot name='start-reading'>
      <p class='sophie-home-card__meta'>This week's lecture:</p>
      <span class='sophie-home-cta'>Begin →</span>
    </slot>
  </div>
</section>

<style>
  .sophie-home-cards {
    display: grid;
    gap: 1.1rem;
    margin-top: clamp(2rem, 5vw, 3.2rem);
    grid-template-columns: repeat(3, 1fr);
  }
  /* The region is named for screen readers but the heading is visually
     redundant with the card labels, so it is visually hidden (not
     `display:none` — that would strip its accessible name). */
  .sophie-home-cards__sr-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .sophie-home-card {
    position: relative;
    border-radius: var(--sophie-home-radius);
    background: var(--sophie-home-glass);
    border: 1px solid var(--sophie-home-glass-brd);
    backdrop-filter: blur(10px);
    padding: 1.35rem 1.4rem 1.5rem;
    overflow: hidden;
    transition:
      transform 0.35s var(--sophie-home-ease),
      border-color 0.35s,
      box-shadow 0.35s;
  }
  .sophie-home-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      120% 80% at 0% 0%,
      rgba(79, 214, 196, 0.1),
      transparent 55%
    );
    opacity: 0.9;
  }
  .sophie-home-card:hover {
    transform: translateY(-4px);
    border-color: var(--sophie-home-glass-brd-lit);
    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.4),
      0 0 26px rgba(79, 214, 196, 0.1);
  }
  .sophie-home-card__label {
    font-family: var(--sophie-font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sophie-home-ink-muted);
    margin: 0 0 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sophie-home-card__ic {
    color: var(--sophie-home-teal);
    font-size: 0.9rem;
  }
  .sophie-home-card__big {
    font-family: var(--sophie-font-serif);
    font-weight: 500;
    font-size: 1.6rem;
    line-height: 1.1;
    color: var(--sophie-home-ink);
    margin: 0;
  }
  .sophie-home-card__meta {
    margin: 0.35rem 0 0;
    color: var(--sophie-home-ink-soft);
    font-size: 0.98rem;
  }
  .sophie-home-due {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 0.55rem;
    font-size: 0.98rem;
  }
  .sophie-home-due__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: none;
    align-self: center;
  }
  .sophie-home-due__dot--soon {
    background: var(--sophie-home-rose);
    box-shadow: 0 0 10px var(--sophie-home-rose);
  }
  .sophie-home-due__when {
    font-family: var(--sophie-font-mono);
    color: var(--sophie-home-ink-soft);
    margin-left: auto;
    font-size: 0.86rem;
  }
  .sophie-home-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.7rem;
    font-weight: 600;
    color: var(--sophie-home-ground);
    text-decoration: none;
    background: linear-gradient(95deg, var(--sophie-home-teal), #79efe0);
    padding: 0.6rem 1.05rem;
    border-radius: 999px;
    box-shadow: 0 0 22px rgba(79, 214, 196, 0.35);
    transition:
      transform 0.25s var(--sophie-home-ease),
      box-shadow 0.25s;
  }
  .sophie-home-cta:hover {
    transform: translateX(3px);
    box-shadow: 0 0 30px rgba(79, 214, 196, 0.55);
  }
  @media (max-width: 820px) {
    .sophie-home-cards {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sophie-home-card,
    .sophie-home-cta {
      transition: none;
    }
  }
</style>
