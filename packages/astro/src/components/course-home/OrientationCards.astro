---
/**
 * <OrientationCards /> — the orientation-card row (ADR 0097 #2/#7):
 * "This Week" · "Due Soon" · "Start Reading". DATA-DRIVEN with graceful
 * degradation (Task 6): only the cards that have data render, so the grid
 * looks intentional with 1–3 cards rather than showing empty chrome.
 *
 * Chrome (role-less, ADR 0058): calendar-aware orientation, not pedagogy.
 *
 * GRACEFUL DEGRADATION (ADR 0097 #7, fail-closed):
 *   - "This Week"    — needs ScheduleSchema (`thisWeek`, ADR 0098, PR 2).
 *                      Always absent in PR 1 → the card is DROPPED (no
 *                      schedule → no card, no crash).
 *   - announcement   — needs Announcements (ADR 0099, PR 3). Absent in
 *                      PR 1 → no banner.
 *   - "Due Soon"     — LIVE from the homework registry (ADR 0096) via the
 *                      `dueSoon` projection. Empty list → the card is
 *                      DROPPED (no "No assignments" empty chrome — the
 *                      honest non-empty-chrome option per ADR 0097 #7).
 *   - "Start Reading" — first non-draft unit; ALWAYS renders (falls back
 *                      to a static prompt when `startReading` is absent,
 *                      e.g. an all-draft course, so the card never breaks).
 *
 * The named slots remain as consumer overrides; the DEFAULT slot content
 * is now the projected data. Each slot's projected data is the seam Task 7
 * fills from the (R12-narrowed) virtual modules + the build wall-clock.
 */
import { withBase } from "../../lib/with-base";
import type { DueSoonItem, StartReadingLink } from "./home-card-projections";

interface Props {
  /** Live homework due-soon rows (ADR 0096). Empty → the card is dropped. */
  dueSoon?: ReadonlyArray<DueSoonItem>;
  /** First non-draft unit link. Absent → the card shows a static prompt. */
  startReading?: StartReadingLink;
}

const { dueSoon = [], startReading } = Astro.props;

const labelId = "sophie-home-cards-heading";
const hasDueSoon = dueSoon.length > 0;
// PR 1: "This Week" has no data source yet (ScheduleSchema, ADR 0098), so
// the card is never rendered. The slot stays a consumer override seam.
const hasThisWeek = false;
const cardCount = (hasThisWeek ? 1 : 0) + (hasDueSoon ? 1 : 0) + 1;
---

<section
  class='sophie-home-cards'
  data-card-count={cardCount}
  aria-labelledby={labelId}
>
  <h2 id={labelId} class='sophie-home-cards__sr-heading'>Course orientation</h2>

  {
    hasThisWeek && (
      <div class='sophie-home-card'>
        <p class='sophie-home-card__label'>
          <span class='sophie-home-card__ic' aria-hidden='true'>
            ◷
          </span>{" "}
          This Week
        </p>
        <slot name='this-week' />
      </div>
    )
  }

  {
    hasDueSoon && (
      <div class='sophie-home-card'>
        <p class='sophie-home-card__label'>
          <span class='sophie-home-card__ic' aria-hidden='true'>
            ◆
          </span>{" "}
          Due Soon
        </p>
        <slot name='due-soon'>
          {dueSoon.map((item) => (
            <div class:list={["sophie-home-due", { "is-tbd": item.tbd }]}>
              <span
                class:list={[
                  "sophie-home-due__dot",
                  item.tbd
                    ? "sophie-home-due__dot--tbd"
                    : "sophie-home-due__dot--soon",
                ]}
              />
              <span class='sophie-home-due__title'>
                {item.title}
                {item.problemCount > 0 && (
                  <span class='sophie-home-due__count'>
                    {`${item.problemCount} ${item.problemCount === 1 ? "problem" : "problems"}`}
                  </span>
                )}
              </span>
              <span class='sophie-home-due__when'>{item.due}</span>
            </div>
          ))}
        </slot>
      </div>
    )
  }

  <div class='sophie-home-card'>
    <p class='sophie-home-card__label'>
      <span class='sophie-home-card__ic' aria-hidden='true'>▸</span> Start
      Reading
    </p>
    <slot name='start-reading'>
      {
        startReading ? (
          <>
            <p class='sophie-home-card__meta'>Begin with:</p>
            <a class='sophie-home-cta' href={startReading.href}>
              {startReading.label} →
            </a>
          </>
        ) : (
          <p class='sophie-home-card__meta'>
            Readings open as the course begins.
          </p>
        )
      }
    </slot>
  </div>
</section>

<style>
  /* The column count tracks the number of rendered cards (1–3) so the row
     stays intentional under graceful degradation (ADR 0097 #7) rather than
     leaving empty 3-up gaps. `data-card-count` is set from the same flags
     that gate the cards, so layout never disagrees with content. */
  .sophie-home-cards {
    display: grid;
    gap: 1.1rem;
    margin-top: clamp(2rem, 5vw, 3.2rem);
    grid-template-columns: repeat(3, 1fr);
  }
  .sophie-home-cards[data-card-count="1"] {
    grid-template-columns: minmax(0, 30rem);
  }
  .sophie-home-cards[data-card-count="2"] {
    grid-template-columns: repeat(2, 1fr);
  }
  /* The region is named for screen readers but the heading is visually
     redundant with the card labels, so it is visually hidden (not
     `display:none` — that would strip its accessible name). */
  .sophie-home-cards__sr-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .sophie-home-card {
    position: relative;
    border-radius: var(--sophie-home-radius);
    background: var(--sophie-home-glass);
    border: 1px solid var(--sophie-home-glass-brd);
    backdrop-filter: blur(10px);
    padding: 1.35rem 1.4rem 1.5rem;
    overflow: hidden;
    transition:
      transform 0.35s var(--sophie-home-ease),
      border-color 0.35s,
      box-shadow 0.35s;
  }
  .sophie-home-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      120% 80% at 0% 0%,
      rgba(79, 214, 196, 0.1),
      transparent 55%
    );
    opacity: 0.9;
  }
  .sophie-home-card:hover {
    transform: translateY(-4px);
    border-color: var(--sophie-home-glass-brd-lit);
    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.4),
      0 0 26px rgba(79, 214, 196, 0.1);
  }
  .sophie-home-card__label {
    font-family: var(--sophie-font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sophie-home-ink-muted);
    margin: 0 0 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sophie-home-card__ic {
    color: var(--sophie-home-teal);
    font-size: 0.9rem;
  }
  .sophie-home-card__meta {
    margin: 0.35rem 0 0;
    color: var(--sophie-home-ink-soft);
    font-size: 0.98rem;
  }
  .sophie-home-due {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 0.55rem;
    font-size: 0.98rem;
  }
  /* tbd rows are dimmed (the prototype's dimmed HW row) — they are real
     upcoming work but the instructor hasn't dated them yet. */
  .sophie-home-due.is-tbd {
    color: var(--sophie-home-ink-muted);
  }
  .sophie-home-due__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: none;
    align-self: center;
  }
  .sophie-home-due__dot--soon {
    background: var(--sophie-home-rose);
    box-shadow: 0 0 10px var(--sophie-home-rose);
  }
  .sophie-home-due__dot--tbd {
    background: var(--sophie-home-ink-muted);
  }
  .sophie-home-due__title {
    flex: 1 1 auto;
    min-width: 0;
  }
  .sophie-home-due__count {
    display: block;
    font-size: 0.8rem;
    color: var(--sophie-home-ink-muted);
    margin-top: 0.1rem;
  }
  .sophie-home-due__when {
    font-family: var(--sophie-font-mono);
    color: var(--sophie-home-ink-soft);
    margin-left: auto;
    font-size: 0.86rem;
  }
  .sophie-home-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.7rem;
    font-weight: 600;
    color: var(--sophie-home-ground);
    text-decoration: none;
    background: linear-gradient(95deg, var(--sophie-home-teal), #79efe0);
    padding: 0.6rem 1.05rem;
    border-radius: 999px;
    box-shadow: 0 0 22px rgba(79, 214, 196, 0.35);
    transition:
      transform 0.25s var(--sophie-home-ease),
      box-shadow 0.25s;
  }
  .sophie-home-cta:hover {
    transform: translateX(3px);
    box-shadow: 0 0 30px rgba(79, 214, 196, 0.55);
  }
  @media (max-width: 820px) {
    .sophie-home-cards,
    .sophie-home-cards[data-card-count="1"],
    .sophie-home-cards[data-card-count="2"] {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sophie-home-card,
    .sophie-home-cta {
      transition: none;
    }
  }
</style>
