---
/**
 * <ModuleList /> — the course-home module roll-up (ADR 0097 #2). One row
 * per Section, numbered, titled, with an optional one-line description and
 * a derived non-draft lecture count. Rows link to the section's first
 * surface (the section slug route).
 *
 * Chrome (role-less, ADR 0058): a navigation projection, not pedagogy.
 *
 * GRACEFUL DEGRADATION (ADR 0097 #7): week-ranges and the "Now" marker
 * come from ScheduleSchema (`virtual:sophie/schedule`, ADR 0098) via the
 * OPTIONAL `scheduleRows` prop the dispatcher projects (Task 8). They are
 * NOT fabricated here: when no schedule row exists for a section's slug
 * (no `scheduleRows`, or no resolvable entries for that section), the
 * `.sophie-home-mod__right` cell renders exactly the lecture-count-only
 * state — no week label, no `Now` tag, no `is-now`/`is-past` row class.
 * The `aria-labelledby` region + grid shape are the stable seam.
 *
 * The `ScheduleRow` import is TYPE-ONLY by design: a value import of
 * `home-schedule-projections` would add it to the tsup `.astro`-derived
 * entry surface (discover-astro-entries). The dispatcher owns the value
 * import + projection; this component only consumes the shape.
 *
 * The orbital SVG is decorative atmosphere → `aria-hidden` + `focusable`
 * off, never announced.
 */
import type { SectionEntry, UnitEntry } from "@sophie/core/schema";
import { withBase } from "../../lib/with-base";
import type { ScheduleRow } from "./home-schedule-projections";
import { type ModuleRow, moduleRows } from "./home-projections";

interface Props {
  sections: ReadonlyArray<SectionEntry>;
  units: ReadonlyArray<UnitEntry>;
  scheduleRows?: ReadonlyArray<ScheduleRow>;
}

const { sections, units, scheduleRows = [] } = Astro.props;
const rows: ModuleRow[] = moduleRows(sections, units);
const scheduleBySlug = new Map(scheduleRows.map((r) => [r.slug, r]));

/**
 * "Weeks N–M" (en-dash, U+2013) for a multi-week span; "Week N" when the
 * span is a single week. `null` when week numbers are absent (`term_start`
 * was `"tbd"` upstream, so the projection omitted `weekStart`/`weekEnd`).
 */
const weekLabel = (row: ScheduleRow): string | null => {
  if (row.weekStart === undefined || row.weekEnd === undefined) return null;
  return row.weekStart === row.weekEnd
    ? `Week ${row.weekStart}`
    : `Weeks ${row.weekStart}–${row.weekEnd}`;
};

const pad = (n: number): string => String(n).padStart(2, "0");
const headingId = "sophie-home-modules-heading";
---

<section class='sophie-home-modules' aria-labelledby={headingId}>
  <svg
    class='sophie-home-modules__orbit'
    viewBox='0 0 600 600'
    aria-hidden='true'
    focusable='false'
  >
    <ellipse cx='300' cy='300' rx='276' ry='186'></ellipse>
    <ellipse cx='300' cy='300' rx='186' ry='124'></ellipse>
    <ellipse cx='300' cy='300' rx='96' ry='64'></ellipse>
    <circle class='sophie-home-modules__node' cx='576' cy='276' r='5'></circle>
    <circle
      class='sophie-home-modules__node sophie-home-modules__node--faint'
      cx='120'
      cy='372'
      r='3'></circle>
  </svg>

  <h2 id={headingId} class='sophie-home-modules__heading'>
    The Course · {rows.length} {rows.length === 1 ? "module" : "modules"}
  </h2>

  {
    rows.map((row) => {
      const schedule = scheduleBySlug.get(row.slug);
      const weeks = schedule ? weekLabel(schedule) : null;
      return (
        <a
          class:list={[
            "sophie-home-mod",
            { "is-now": schedule?.isNow, "is-past": schedule?.isPast },
          ]}
          href={withBase(`/sections/${row.slug}/`)}
        >
          <span class='sophie-home-mod__num'>{pad(row.number)}</span>
          <span class='sophie-home-mod__title'>
            {row.title}
            {row.description && (
              <span class='sophie-home-mod__desc'>{row.description}</span>
            )}
          </span>
          <span class='sophie-home-mod__right'>
            {schedule?.isNow && (
              <span class='sophie-home-mod__now'>Now</span>
            )}
            {weeks && <span class='sophie-home-mod__weeks'>{weeks}</span>}
            <span class='sophie-home-mod__count'>
              {row.lectureCount}{" "}
              {row.lectureCount === 1 ? "lecture" : "lectures"}
            </span>
          </span>
        </a>
      );
    })
  }
</section>

<style>
  .sophie-home-modules {
    margin-top: clamp(2.6rem, 6vw, 4rem);
    position: relative;
  }
  .sophie-home-modules__orbit {
    position: absolute;
    right: -150px;
    top: 52%;
    transform: translateY(-50%);
    width: 560px;
    height: 560px;
    z-index: -1;
    pointer-events: none;
    opacity: 0.55;
    mask-image: radial-gradient(70% 70% at 60% 50%, #000 40%, transparent 78%);
  }
  .sophie-home-modules__orbit ellipse {
    fill: none;
    stroke: rgba(120, 225, 210, 0.2);
    stroke-width: 1;
  }
  .sophie-home-modules__orbit ellipse:nth-of-type(2) {
    stroke: rgba(160, 139, 255, 0.18);
  }
  .sophie-home-modules__orbit ellipse:nth-of-type(3) {
    stroke: rgba(120, 225, 210, 0.12);
  }
  .sophie-home-modules__node {
    fill: var(--sophie-home-teal);
    filter: drop-shadow(0 0 7px var(--sophie-home-teal));
  }
  .sophie-home-modules__node--faint {
    fill: var(--sophie-home-violet);
    opacity: 0.6;
    filter: drop-shadow(0 0 5px var(--sophie-home-violet));
  }
  .sophie-home-modules__heading {
    font-family: var(--sophie-font-mono);
    font-weight: 500;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--sophie-home-ink-muted);
    margin: 0 0 0.4rem;
  }
  .sophie-home-mod {
    position: relative;
    display: grid;
    grid-template-columns: 3.2rem 1fr auto;
    align-items: center;
    gap: 1.1rem;
    padding: 1.15rem 0.4rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid rgba(160, 170, 230, 0.1);
    transition:
      background 0.3s,
      padding-left 0.3s var(--sophie-home-ease);
  }
  .sophie-home-mod:hover {
    background: linear-gradient(90deg, rgba(79, 214, 196, 0.06), transparent);
    padding-left: 1rem;
  }
  .sophie-home-mod__num {
    font-family: var(--sophie-font-serif);
    font-size: 1.5rem;
    color: var(--sophie-home-ink-muted);
    font-weight: 500;
  }
  .sophie-home-mod__title {
    font-family: var(--sophie-font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--sophie-home-ink);
  }
  .sophie-home-mod__desc {
    display: block;
    font-family: var(--sophie-font-sans);
    font-size: 0.82rem;
    color: var(--sophie-home-ink-muted);
    letter-spacing: 0.02em;
    margin-top: 0.1rem;
  }
  .sophie-home-mod__right {
    font-family: var(--sophie-font-mono);
    font-size: 0.8rem;
    color: var(--sophie-home-ink-muted);
    display: flex;
    align-items: center;
    gap: 0.9rem;
    white-space: nowrap;
  }
  .sophie-home-mod__weeks {
    color: var(--sophie-home-ink-soft);
  }
  /* "Now" pill: a TEXT label (never color-only), teal-accented to flag the
     section in session — mirrors the Due-Soon kind badge idiom but lit
     rather than muted so it reads as the live row. */
  .sophie-home-mod__now {
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sophie-home-teal);
    border: 1px solid color-mix(in srgb, var(--sophie-home-teal) 45%, transparent);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    box-shadow: 0 0 12px color-mix(in srgb, var(--sophie-home-teal) 22%, transparent);
  }
  /* Current section: a thin teal rail + a faint wash mark the live row. */
  .sophie-home-mod.is-now {
    box-shadow: inset 2px 0 0 var(--sophie-home-teal);
    background: linear-gradient(90deg, rgba(79, 214, 196, 0.05), transparent);
  }
  /* Past section: dim the whole row toward the muted ink so the eye lands
     on what's current/upcoming first. */
  .sophie-home-mod.is-past {
    opacity: 0.6;
  }
  @media (max-width: 820px) {
    .sophie-home-mod {
      grid-template-columns: 2.4rem 1fr;
    }
    .sophie-home-mod__right {
      display: none;
    }
    .sophie-home-modules__orbit {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sophie-home-mod {
      transition: none;
    }
  }
</style>
