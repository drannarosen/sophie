---
/**
 * <HowBand /> — the "How each lecture works" descriptive band (ADR 0097
 * #3). The Observable → Model → Inference → Assumption-audit flow plus the
 * two-depth Track A / Track B reading note, ported from the prototype's
 * `.how` / `.flow` / `.step` / `.arrow` / `.how-note`.
 *
 * Chrome (role-less, ADR 0058): a course-spec PROJECTION of the
 * `pedagogy` cluster, NOT a pedagogy primitive. No epistemicRole; never
 * enters the pedagogy index / Library; wired via the chrome path (lives in
 * @sophie/astro, outside the R13 gate's `packages/components` scope — a
 * documentary CHROME allowlist entry mirrors the sibling pieces).
 *
 * FULLY PROJECTED (no fixed editorial copy in this band):
 *   - `flow`  — the REAL `pedagogy.required_moves` keys (humanized labels)
 *               + their verbatim one-line descriptions (`howFlow`). A
 *               course that renames/reorders its moves renders its own.
 *   - `note`  — the Track labels + target times from
 *               `multi_track_readings` (`trackNote`).
 * The projection lives in `home-projections.ts` (`howBand`); this piece is
 * presentational.
 *
 * GRACEFUL DEGRADATION (ADR 0097 #7): the route omits this band entirely
 * when `flow` is empty (absent `required_moves`), so the piece never
 * renders an empty flow. The track `note` is independently optional —
 * absent / `enabled: false` / no tracks → the note line is omitted.
 *
 * The `→` separators are decorative (`aria-hidden`); the step labels and
 * captions carry the meaning, so a screen reader reads the four moves in
 * order without spurious "right arrow" announcements.
 *
 * LANDMARK (R10): a `<section aria-labelledby>` named region nested under
 * the shell's single `<main>` — never a second `<main>`.
 */
import type { FlowStep, TrackNote } from "./home-projections";

interface Props {
  /** Ordered OMI flow steps (projected from required_moves). */
  flow: ReadonlyArray<FlowStep>;
  /** Optional two-depth track note; absent → no note line. */
  note?: TrackNote;
}

const { flow, note } = Astro.props;
const headingId = "sophie-home-how-heading";
---

<section class='sophie-home-how' aria-labelledby={headingId}>
  <h2 id={headingId} class='sophie-home-how__label'>
    How each lecture works
  </h2>
  <div class='sophie-home-how__flow'>
    {
      flow.map((step, index) => (
        <>
          {index > 0 && (
            <span class='sophie-home-how__arrow' aria-hidden='true'>→</span>
          )}
          <span class='sophie-home-how__step'>
            <b>{step.label}</b>
            <span>{step.caption}</span>
          </span>
        </>
      ))
    }
  </div>
  {
    note && (
      <p class='sophie-home-how__note'>
        Every reading comes in
        {note.tracks.length === 1 ? " one depth — " : " two depths — "}
        {note.tracks.map((track, index) => (
          <>
            {index > 0 && " and "}
            <strong>{track.label}</strong>
            {` (${track.time})`}
          </>
        ))}
        {" — so you choose how far to go."}
      </p>
    )
  }
</section>

<style>
  .sophie-home-how {
    margin-top: clamp(3rem, 7vw, 5rem);
  }
  .sophie-home-how__label {
    font-family: var(--sophie-font-mono);
    font-weight: 500;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--sophie-home-ink-muted);
    margin: 0 0 1.2rem;
  }
  .sophie-home-how__flow {
    display: flex;
    align-items: stretch;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
  .sophie-home-how__step {
    flex: 1 1 0;
    min-width: 148px;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.05rem 1.15rem;
    border-radius: 12px;
    background: var(--sophie-home-glass);
    border: 1px solid var(--sophie-home-glass-brd);
  }
  .sophie-home-how__step b {
    font-family: var(--sophie-font-serif);
    font-weight: 500;
    font-size: 1.12rem;
    color: var(--sophie-home-ink);
  }
  .sophie-home-how__step span {
    font-size: 0.84rem;
    color: var(--sophie-home-ink-muted);
  }
  .sophie-home-how__arrow {
    align-self: center;
    color: var(--sophie-home-teal);
    font-size: 1.1rem;
  }
  .sophie-home-how__note {
    margin: 1.4rem 0 0;
    color: var(--sophie-home-ink-soft);
    font-size: 1rem;
  }
  .sophie-home-how__note strong {
    color: var(--sophie-home-ink);
    font-weight: 600;
  }
  @media (max-width: 820px) {
    .sophie-home-how__arrow {
      display: none;
    }
  }
</style>
