---
/**
 * <AnnouncementBanner /> — the course-home announcement banner (ADR 0099,
 * ADR 0097 #5). Renders the currently-active announcements as a stacked,
 * non-dismissible banner at the top of the dashboard `<main>`.
 *
 * Chrome (role-less, ADR 0058): a build-time course-info projection, not
 * pedagogy — never enters the pedagogy-index / Library. R13 (epistemic-role)
 * scopes to `@sophie/components` only, so no role declaration is needed here.
 *
 * BUILD-TIME GATED, NO CLIENT JS: the items arrive already filtered to the
 * active publish window + sorted (severity → publish_date desc) by the
 * `activeAnnouncements` projection (the dispatcher owns the impure
 * virtual-module read + wall-clock; Task 5 mounts this gated by
 * `landing.show_announcements && active.length > 0`). The banner is pure
 * static markup — non-dismissible by design (the publish/expire window
 * bounds nagging, fitting the no-accounts LDS model; ADR 0099). The order
 * received is rendered as-is — do NOT re-sort.
 *
 * GRACEFUL DEGRADATION (fail-closed, ADR 0097 #7): an empty array renders
 * NOTHING — no labelled region, no empty chrome.
 *
 * SEVERITY is a TEXT signal (WCAG 1.4.1), never color-only: the capitalized
 * word ("Urgent" / "Notice" / "Info") carries the meaning; the scoped
 * `--sophie-home-*` palette accent (rose / violet / teal) is supplementary.
 */
import type { ActiveAnnouncement } from "./home-announcement-projections";

interface Props {
  announcements?: ReadonlyArray<ActiveAnnouncement>;
}

const { announcements = [] } = Astro.props;

const headingId = "sophie-home-announcements-heading";

/** "info" → "Info" — the capitalized severity word (the non-color signal). */
const severityLabel = (severity: ActiveAnnouncement["severity"]): string =>
  severity.charAt(0).toUpperCase() + severity.slice(1);
---

{
  announcements.length > 0 && (
    <section class='sophie-home-announce' aria-labelledby={headingId}>
      <h2 id={headingId} class='sophie-home-announce__sr-heading'>
        Course announcements
      </h2>
      {announcements.map((a) => (
        <div
          class='sophie-home-announce__item'
          data-severity={a.severity}
        >
          <span class='sophie-home-announce__sev'>{severityLabel(a.severity)}</span>
          <div class='sophie-home-announce__body'>
            <p class='sophie-home-announce__title'>{a.title}</p>
            {a.body && <p class='sophie-home-announce__text'>{a.body}</p>}
            {a.href && (
              /* Author-provided URL (NonEmptyString, possibly external):
                 rendered RAW, not through `withBase`. `withBase` prefixes
                 the consumer's base for internal absolute PATHS and would
                 corrupt an external `https://…` URL. There is no rendered
                 `landing.hero.cta.href` precedent to mirror, so the raw
                 author-href treatment is the correct default. */
              <a class='sophie-home-announce__link' href={a.href}>
                Details →
              </a>
            )}
          </div>
        </div>
      ))}
    </section>
  )
}

<style>
  /* Stacked announcement banner. Mirrors the sibling glass-card idiom
     (OrientationCards / ModuleList) on the scoped Deep Field palette
     (CourseHomeShell `--sophie-home-*`), with a per-severity left rail +
     accent. The severity WORD is the signal; the color is supplementary. */
  .sophie-home-announce {
    display: grid;
    gap: 0.75rem;
    margin-top: clamp(1.4rem, 4vw, 2.2rem);
  }
  /* The region is named for screen readers but the heading is visually
     redundant with the per-item severity labels, so it is visually hidden
     (clip-rect, NOT `display:none` — that would strip its accessible
     name). Mirrors OrientationCards' `__sr-heading`. */
  .sophie-home-announce__sr-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .sophie-home-announce__item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    border-radius: var(--sophie-home-radius);
    background: var(--sophie-home-glass);
    border: 1px solid var(--sophie-home-glass-brd);
    /* Severity accent: a left rail in the per-severity hue (set below). The
       rail is decorative — the severity WORD carries the meaning. */
    border-left: 3px solid var(--sophie-home-announce-accent);
    backdrop-filter: blur(10px);
    padding: 1rem 1.2rem;
  }
  /* Severity → scoped palette (CourseHomeShell:235). Default (info) → teal;
     notice → violet; urgent → rose. A custom property the rail + pill share
     so the per-severity color lives in exactly one place per item. */
  .sophie-home-announce__item {
    --sophie-home-announce-accent: var(--sophie-home-teal);
  }
  .sophie-home-announce__item[data-severity="notice"] {
    --sophie-home-announce-accent: var(--sophie-home-violet);
  }
  .sophie-home-announce__item[data-severity="urgent"] {
    --sophie-home-announce-accent: var(--sophie-home-rose);
  }
  /* Severity pill: a TEXT label (never color-only), tinted to the severity
     hue — mirrors the ModuleList "Now" pill idiom (bordered mono badge,
     lit rather than muted so it reads as the live signal). */
  .sophie-home-announce__sev {
    flex: none;
    font-family: var(--sophie-font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sophie-home-announce-accent);
    border: 1px solid
      color-mix(in srgb, var(--sophie-home-announce-accent) 45%, transparent);
    border-radius: 999px;
    padding: 0.18rem 0.6rem;
    margin-top: 0.1rem;
    box-shadow: 0 0
      12px color-mix(in srgb, var(--sophie-home-announce-accent) 22%, transparent);
  }
  .sophie-home-announce__body {
    min-width: 0;
    flex: 1 1 auto;
  }
  .sophie-home-announce__title {
    margin: 0;
    font-weight: 600;
    color: var(--sophie-home-ink);
    font-size: 1rem;
  }
  .sophie-home-announce__text {
    margin: 0.35rem 0 0;
    color: var(--sophie-home-ink-soft);
    font-size: 0.95rem;
  }
  .sophie-home-announce__link {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--sophie-font-mono);
    font-size: 0.82rem;
    color: var(--sophie-home-announce-accent);
    text-decoration: none;
    border-bottom: 1px solid
      color-mix(in srgb, var(--sophie-home-announce-accent) 40%, transparent);
    transition: border-color 0.25s;
  }
  .sophie-home-announce__link:hover {
    border-bottom-color: var(--sophie-home-announce-accent);
  }
  @media (max-width: 820px) {
    .sophie-home-announce__item {
      flex-direction: column;
      gap: 0.5rem;
    }
    .sophie-home-announce__sev {
      align-self: flex-start;
    }
  }
</style>
