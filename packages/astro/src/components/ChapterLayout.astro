---
import ChapterFooter from "@sophie/astro/components/ChapterFooter.astro";
import ChapterMeta from "@sophie/astro/components/ChapterMeta.astro";
import ChapterPagination from "@sophie/astro/components/ChapterPagination.astro";
import ChapterTitle from "@sophie/astro/components/ChapterTitle.astro";
import ModuleNav from "@sophie/astro/components/ModuleNav.astro";
import ScrollProgress from "@sophie/astro/components/ScrollProgress.astro";
import TextbookHead from "@sophie/astro/components/TextbookHead.astro";
import TextbookLayout from "@sophie/astro/components/TextbookLayout.astro";
import TocDrawer from "@sophie/astro/components/TocDrawer.astro";
import TocSidebar from "@sophie/astro/components/TocSidebar.astro";
import UnitViewLinkBar from "./UnitViewLinkBar.astro";
import { buildModuleNavInputs, indexAccumulator } from "@sophie/astro";
import { SophieChapter } from "@sophie/astro/client";
import { getCollection } from "astro:content";
import type { MarkdownHeading } from "astro";
import { figures as figureRegistry } from "virtual:sophie/figures";
import {
  getAvailableUnitViews,
  type UnitViewKind,
} from "../lib/unit-views";
import { withBase } from "../lib/with-base";

// Convert the consumer-owned figures registry (a named-keyed map; see
// `src/content/figures.ts`) into the array shape `<TextbookLayout>`
// expects so `<FigureRef>` can hydrate its registry store on every page.
const figureRegistryArray = Object.values(figureRegistry);

interface Props {
  frontmatter: {
    title: string;
    /** Sprint K — optional editorial subtitle / deck. */
    subtitle?: string;
    /** W2/D1 — ArtifactEntry id (== unit id per W2/D4 1:1 convention). */
    id: string;
    order?: number;
    lang?: string;
    description?: string;
    /** Sprint F — display chapter number for "Figure C.N" / "Eq. C.N". */
    chapter?: number;
    /** Sprint I-A — reading-time estimate. */
    reading?: { min: number; max: number };
    /** Sprint I-A — difficulty track marker. */
    track?: "A" | "B";
    /** Sprint I-D — chapter authorship byline. */
    authors?: string[];
    /** Sprint I-D — last-revised ISO date string. */
    updated?: string;
    /** Sprint I-D — AI-contribution disclosure per ADR 0042. */
    ai_contribution?: {
      visibility: "public" | "private";
      models?: string[];
      review_depth?: string;
    };
  };
  /**
   * Unit id of the chapter currently being rendered. Per W2/D4
   * convention this is the same as the reading-artifact's id and the
   * URL slug at `/units/<unit-id>/reading`. The prop name is retained
   * for back-compat with non-W2 callers; W3 renames to `currentUnitId`.
   */
  currentChapterSlug?: string;
  /** Chapter headings (h1-h6) extracted by Astro's render(). */
  headings?: ReadonlyArray<MarkdownHeading>;
  /**
   * Which peer-view is currently rendered — `reading` (default),
   * `slides`, or `practice`. Per ADR 0073 Amendment 1 §7: drives the
   * `<UnitViewLinkBar>` `aria-current` state and the trailing
   * "Practice this lecture" CTA (rendered only on reading views when
   * the unit also ships a practice artifact).
   */
  viewKind?: UnitViewKind;
}

const {
  frontmatter,
  currentChapterSlug,
  headings = [],
  viewKind = "reading",
} = Astro.props;

// Only populate the right-column slot when the chapter has H2 headings.
const hasToc = headings.some((h) => h.depth === 2);

// W2/D1 — fetch sections + units from the new content collections.
// Use the shared `buildModuleNavInputs` helper (W4b R+CR I5 follow-
// up) so bridge sections (ADR 0068 Scale 1, W4b) stay out of the
// module → chapter sidebar tree — bridges render at Course root
// and don't share the `/units/<u>/reading` URL pattern that
// ModuleNav links into.
const sections = (await getCollection("sections")).map((s) => s.data);
const units = (await getCollection("units")).map((u) => u.data);
const { modules, chapters: navChapters } = buildModuleNavInputs(
  sections,
  units,
);

// ADR 0073 Amendment 1 §7 — derive the peer-view set (reading | slides
// | practice) available for the current unit. Drives the
// <UnitViewLinkBar> + the trailing "Practice this lecture" CTA on
// reading views. `currentChapterSlug` IS the unit id per W2/D4.
const artifacts = await getCollection("artifacts");
const draftUnitIds = new Set(
  units.filter((u) => u.status === "draft").map((u) => u.id),
);
const unitIdForViews = currentChapterSlug ?? "";
const availableViews = getAvailableUnitViews({
  unit: unitIdForViews,
  artifacts,
  draftUnitIds,
});
// Pagination sort needs `status` to filter drafts; the helper drops
// that field for nav-purity. Derive a paginable list with the same
// bridge-filtering applied (so prev/next never points at a bridge
// Unit whose `/units/<u>/reading` URL doesn't exist).
const bridgeSectionSlugs = new Set(
  sections.filter((s) => s.type === "bridge").map((s) => s.slug),
);
const chapters = units
  .filter((u) => !bridgeSectionSlugs.has(u.section_id))
  .map((u) => ({
    slug: u.id,
    title: u.title,
    module: u.section_id,
    order: u.order,
    chapter: undefined as number | undefined,
    status: u.status,
  }));

// W2/D2 — derive the topbar breadcrumb context. The current Unit's
// section_id resolves to the matching Section; its `order` field
// becomes the "MOD N" rung. `chapter: 3` (numeric) from the artifact
// frontmatter becomes the "LECTURE M" rung. `status` is the Unit
// maturity enum (draft | review | stable) per W2/D2 Placement 1.
const currentUnit = units.find((u) => u.id === currentChapterSlug);
const currentSection = currentUnit
  ? sections.find((s) => s.slug === currentUnit.section_id)
  : undefined;
const chapterContext = {
  moduleOrder: currentSection?.order,
  chapterNumber: frontmatter.chapter,
  status: currentUnit?.status,
};

// Adjacent-unit resolution for prev/next pills. Stable sort by
// (section order, unit order, title). Drafts stay excluded from
// navigation.
const sectionOrder = new Map(sections.map((s) => [s.slug, s.order] as const));
const sortableChapters = chapters
  .filter((c) => c.status !== "draft")
  .slice()
  .sort((a, b) => {
    const mA = sectionOrder.get(a.module) ?? Number.POSITIVE_INFINITY;
    const mB = sectionOrder.get(b.module) ?? Number.POSITIVE_INFINITY;
    if (mA !== mB) return mA - mB;
    if (a.order !== b.order) return a.order - b.order;
    return a.title.localeCompare(b.title);
  });
const currentIdx = currentChapterSlug
  ? sortableChapters.findIndex((c) => c.slug === currentChapterSlug)
  : -1;
const previousRaw =
  currentIdx > 0 ? sortableChapters[currentIdx - 1] ?? null : null;
const nextRaw =
  currentIdx >= 0 && currentIdx < sortableChapters.length - 1
    ? sortableChapters[currentIdx + 1] ?? null
    : null;

// Pagination pill thumbnails. For each adjacent unit, resolve its
// first <Figure> callsite from the pedagogy index and look up the
// registry entry for its src + alt. Pills without a resolvable figure
// render text-only.
const pedagogySnapshot = indexAccumulator.asPedagogyIndex();
function firstFigureThumbnailFor(
  unitId: string
): { src: string; alt: string } | undefined {
  const usage = pedagogySnapshot.figureUsages
    .filter((u) => u.unit === unitId)
    .sort((a, b) => a.number - b.number)[0];
  if (!usage) return undefined;
  const entry = figureRegistry[usage.name];
  // ADR 0094: `src` is optional on the entry type. The resolved registry
  // fills it (optimized → _astro/ URL; legacy → public URL), so this
  // guard degrades gracefully for the rare entry carrying neither.
  if (!entry || entry.src === undefined) return undefined;
  return { src: entry.src, alt: entry.alt };
}
const previous = previousRaw
  ? { ...previousRaw, thumbnail: firstFigureThumbnailFor(previousRaw.slug) }
  : null;
const next = nextRaw
  ? { ...nextRaw, thumbnail: firstFigureThumbnailFor(nextRaw.slug) }
  : null;
---

<html lang={frontmatter.lang ?? "en"}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{frontmatter.title}</title>
    {
      frontmatter.description && (
        <meta name='description' content={frontmatter.description} />
      )
    }
    <TextbookHead />
  </head>
  <body>
    <SophieChapter client:load>
      <ScrollProgress />
      <TextbookLayout
        figureRegistry={figureRegistryArray}
        chapterContext={chapterContext}
      >
        <Fragment slot='sidebar'>
          <ModuleNav
            modules={modules}
            chapters={navChapters}
            currentChapterSlug={currentChapterSlug}
          />
        </Fragment>
        {
          hasToc && (
            <Fragment slot='right'>
              <TocSidebar headings={headings} />
            </Fragment>
          )
        }
        <ChapterTitle frontmatter={frontmatter} />
        <ChapterMeta
          reading={frontmatter.reading}
          track={frontmatter.track}
        />
        {
          availableViews.length > 1 && (
            <UnitViewLinkBar
              unit={unitIdForViews}
              current={viewKind}
              availableViews={availableViews}
            />
          )
        }
        <slot />
        {
          viewKind === "reading" && availableViews.includes("practice") && (
            <aside class='sophie-reading-end-cta'>
              <a
                href={withBase(`/units/${unitIdForViews}/practice`)}
                class='sophie-reading-end-cta__link'
              >
                → Practice this lecture
              </a>
            </aside>
          )
        }
        <ChapterPagination previous={previous} next={next} />
        <ChapterFooter
          authors={frontmatter.authors}
          updated={frontmatter.updated}
          ai={frontmatter.ai_contribution}
        />
      </TextbookLayout>
      <TocDrawer headings={headings} />
    </SophieChapter>
  </body>
</html>
