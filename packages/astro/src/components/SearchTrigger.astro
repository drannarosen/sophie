---
import { SearchModal } from "@sophie/components";

/**
 * <SearchTrigger> — Pagefind faceted search affordance in chapter chrome.
 *
 * Static Astro button (paint-fast discovery — visible immediately, no
 * React hydration delay) plus the `<SearchModal client:idle>` React
 * island that defers hydration until after the chapter's primary
 * content paints.
 *
 * The button is a visible/keyboard-discoverable affordance; the
 * primary entry is Cmd/Ctrl+K, handled by SearchModal's own
 * document-level keydown listener (ADR 0037 cross-bundle pattern not
 * required for v1 since the modal owns its own open state). Future
 * polish: a click handler dispatching a synthetic keyboard event
 * (design doc §11 follow-up).
 *
 * `data-pagefind-ignore` keeps the trigger's own UI strings ("Search",
 * "⌘K") out of the next build's index — without it, Pagefind would
 * surface the trigger as a hit on its own.
 *
 * `aria-keyshortcuts` advertises the Cmd/Ctrl+K binding to assistive
 * tech that exposes keyboard shortcut hints.
 *
 * Styles live in `packages/astro/src/styles/textbook-layout.css`
 * alongside other chrome (TopBar, Sidebar, RightColumn) so the
 * cascading `@media print` chrome-reset rule applies without
 * specificity fights from a per-component scoped style block.
 */
---

<button
  type='button'
  class='sophie-search-trigger'
  data-pagefind-ignore
  aria-keyshortcuts='Control+K Meta+K'
  aria-label='Open search'
>
  <span class='sophie-search-trigger__icon' aria-hidden='true'>🔍</span>
  <span class='sophie-search-trigger__label'>Search</span>
  <kbd class='sophie-search-trigger__kbd'>⌘K</kbd>
</button>

<SearchModal client:idle />
