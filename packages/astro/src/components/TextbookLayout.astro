---
import "../styles/textbook-layout.css";
// Store-hydration setters live at an internal subpath (per ADR 0061
// Rule 4 + 2026-05-19 architecture audit P2 #3). TextbookLayout is
// the only consumer; consumer apps never call these directly.
import {
  __setArtifacts,
  __setCourseSpec,
  __setEquationCitations,
  __setEquations,
  __setFigureRegistry,
  __setFigureUsages,
  __setGlossaryDefinitions,
  __setObjectives,
  __setSections,
  __setUnits,
} from "@sophie/components/internal/store-hydration";
import type { FigureRegistryEntry } from "@sophie/core/schema";
import { type CollectionEntry, getCollection, render } from "astro:content";
import { artifactsFromCollection } from "../lib/artifacts-from-collection";
import {
  auditExitCode,
  formatAuditReport,
  formatAuditThrowMessage,
  runAuditOncePerProcess,
} from "../lib/audit-cache";
import { loadConsumerRegistry } from "../lib/notation-registry-loader";
import { indexAccumulator } from "../lib/pedagogy-index/accumulator";
import { extractContractValidations } from "../lib/validation/extractor";
import ChapterBreadcrumb from "./ChapterBreadcrumb.astro";
import ChapterStatusChip from "./ChapterStatusChip.astro";
import ContentColumn from "./ContentColumn.astro";
import RightColumn from "./RightColumn.astro";
import SearchTrigger from "./SearchTrigger.astro";
import DisclosuresToggle from "./DisclosuresToggle.astro";
import Sidebar from "./Sidebar.astro";
import SidebarToggle from "./SidebarToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";
import TopBar from "./TopBar.astro";
import ViewModeToggle from "./ViewModeToggle.astro";
// Course-info projection (2026-05-26) — consumer's parsed
// course.sophie.yaml exposed as a virtual module. `null` when the
// consumer hasn't authored a spec yet; SSR-side __setCourseSpec
// guards on null below.
import { courseSpec } from "virtual:sophie/course-spec";

interface Props {
  /**
   * Figure registry from the consumer app's `content/figures.ts`.
   * PR-C3 addition. The pedagogy-index accumulator never populates
   * `figureRegistry` (its `figureRegistry` is always `[]` per the
   * two-tier model — decision #3 of the PR-C3 design doc); the
   * consumer app owns the registry as build-time content and passes
   * it through this prop. Defaults to `[]` so consumers that don't
   * use `<FigureRef>` keep working unchanged.
   */
  figureRegistry?: ReadonlyArray<FigureRegistryEntry>;
  /**
   * Optional chapter context. When provided, the topbar renders a
   * label-voice "MOD N · LECTURE M" breadcrumb on the leading side
   * and an editorial-status chip ("UNDER REVIEW" / "DRAFT") on the
   * trailing side. Index / glossary / overview pages omit this prop
   * and the topbar stays utility-only.
   */
  chapterContext?: {
    moduleOrder?: number;
    chapterNumber?: number;
    status?: "draft" | "review" | "stable";
  };
  /**
   * Sprint K hardening (2026-05-21): governs the ToC-close cap-cascade.
   *
   * - `"present"` (default): closing the ToC hides the ToC element
   *   only; the right column stays at 280px so docked margin asides
   *   stay anchored, and the content cap does not widen.
   * - `"absent"`: closing the ToC also collapses `--sophie-right-w`
   *   to 0 and widens the content cap. For pages with no margin
   *   asides (stubs, glossary, course index, overview pages).
   *
   * This is a layout-level opt-in, NOT a user toggle — switching it
   * mid-read would shift the column unexpectedly. Consumer apps pass
   * `dockedAsides="absent"` when the rendered chapter content has no
   * `<Aside variant="margin">` (or equivalent docked-aside) usages.
   *
   * Defaults to `"present"` to preserve current behavior on every
   * existing route until consumers opt routes in explicitly.
   */
  dockedAsides?: "present" | "absent";
}
const {
  figureRegistry = [],
  chapterContext,
  dockedAsides = "present",
} = Astro.props;

// Wire the build-time pedagogy index (ADR 0038) into the
// @sophie/components pedagogy stores so <GlossaryTerm> and <EquationRef>
// in this page's MDX content can resolve definitions and equations.
//
// Build-order subtlety: Astro's content-collection layer only
// triggers MDX parse (which runs the pedagogy-index remark
// plugin) on `render(chapter)` — getCollection alone returns
// metadata without parsing. To populate the index BEFORE the
// current page renders MDX that references it, we force every
// chapter's render() to resolve. Promise.all parallelizes; Astro
// caches results so subsequent pages don't re-parse.
//
// Why we read indexAccumulator directly rather than via
// `virtual:sophie/pedagogy-index`: Vite caches the virtual
// module's first load() result, and that load fires BEFORE
// chapter MDX parses (observed in dev + build). The virtual
// module + its Vite plugin remain in @sophie/astro for future
// consumers that want a portable read-only surface, but the
// chrome layer takes the direct route to sidestep the cache.
// ADR 0038 deviation noted in the PR-C1 design doc + PR
// description.
//
// @sophie/components stays Vite-protocol-agnostic (which keeps
// Astro config's bare-Node loader working) by receiving the
// definitions and equations through its `__setGlossaryDefinitions`
// and `__setEquations` setters rather than importing the virtual
// module itself.
// W2/D1 (Path A) per ADR 0067: read the canonical Section + Unit +
// Artifact content collections. ADR 0051 draft semantics now live on
// UnitEntry.status (per W2/D2 Placement 1) — read ALL units so the
// audit can surface CS2 INFO for any drafts; the route filter
// (in consumer-app's pages/units/[unit]/reading.astro) does the
// student-build filter at routing time.
const sections: CollectionEntry<"sections">[] = await getCollection("sections");
const units: CollectionEntry<"units">[] = await getCollection("units");
const allArtifacts: CollectionEntry<"artifacts">[] =
  await getCollection("artifacts");
await Promise.all(allArtifacts.map((a) => render(a)));
// ADR 0060 registry pattern: force every equation registry MDX through
// our remark plugin BEFORE the audit runs, so R1/R4 see a complete
// declarations-vs-citations picture. In production, Astro pre-renders
// every page (including /equations/<id>), so the accumulator is
// populated by build-end. In dev, content collections are processed
// lazily on request — without this eager render, requesting a chapter
// before any /equations/<id> page fires R1 ("citation without
// declaration") because the registry MDX hasn't been processed yet.
// Mirrors the artifacts eager-render above.
const equationEntries: CollectionEntry<"equations">[] =
  await getCollection("equations");
await Promise.all(equationEntries.map((e) => render(e)));
// Push the consumer-supplied figure registry into the accumulator
// BEFORE snapshotting / before the slot renders so that
// <CourseFigures> and <ChapterFigures> (which read figureRegistry via
// asPedagogyIndex()) see a populated registry. Two-tier model
// (PR-C3 decision #3): the extractor produces figureUsages from
// in-MDX <Figure> walks; the registry of canonical image metadata
// is consumer-owned content (smoke's `src/content/figures.ts`).
indexAccumulator.setFigureRegistry(figureRegistry);
// W2/D1 per ADR 0067 + design doc D1 + D7: push the consumer-owned
// sections + units + artifacts into the accumulator. Same
// consumer-global semantics as setFigureRegistry: last-write-wins,
// NOT touched by `clearUnit`. The audit reads these for the
// graduated invariants (PRA-1 Unit-aware, SR-1 section-validity,
// OF-2 framing on UnitEntry, CT-1/CT-2/K1/O2/MG2 all iterating
// index.units now).
indexAccumulator.setSections(sections.map((s) => s.data));
indexAccumulator.setUnits(units.map((u) => u.data));
indexAccumulator.setArtifacts(artifactsFromCollection(allArtifacts));
const pedagogy = indexAccumulator.asPedagogyIndex();
// Pedagogy audit (ADR 0073 PR-C4 + ADR 0088). DEV ONLY: run the audit
// per-render so authors get live HMR feedback as they edit. In a PROD
// build the corpus-wide audit runs ONCE at the integration's
// `astro:build:done` hook (ADR 0088) — which reads this same accumulator,
// extracts contract validations there (once, not per page), and emits
// `dist/.sophie/pedagogy-audit.json` + gates. So the layout neither
// extracts contracts nor audits/gates in prod; `import.meta.env.DEV` is
// statically false in a prod build, so Vite tree-shakes this whole block
// (and its dev-only imports) out of the bundle.
if (import.meta.env.DEV) {
  // ADR 0056 PR 3: walk docs/website/{decisions,reference}/ to collect
  // contract validations (V0+V8 surfaced as extractor findings; V1–V7 run
  // in the audit). `process.cwd()` is the consumer-app dir, which IS the
  // repo root for the smoke fixture + the canonical Sophie layout; evidence
  // refs resolve against the same `repoRoot` passed to runPedagogyAudit.
  const repoRoot = process.cwd();
  const { entries: contractValidations, findings: extractorFindings } =
    await extractContractValidations(repoRoot);
  indexAccumulator.setContractValidations(
    contractValidations,
    extractorFindings
  );
  // ADR 0051 CS2: draft status lives on UnitEntry; one CS2 INFO per draft.
  const draftUnitIds = units
    .filter((u) => u.data.status === "draft")
    .map((u) => u.data.id);
  // PR-ε: consumer Notation Registry (ADR 0043), module-cached so this is
  // free when <ChapterMultiReps> already loaded it during MDX render.
  // `{ registry: null }` when the consumer hasn't opted in (NR/MR skip).
  const { registry: notationRegistry } = loadConsumerRegistry(repoRoot);
  const auditReport = runAuditOncePerProcess(
    indexAccumulator.asPedagogyIndex(),
    { draftUnitIds, repoRoot, notationRegistry },
    import.meta.env.PROD
  );
  if (auditReport !== null) {
    console.log(formatAuditReport(auditReport));
    if (auditExitCode(auditReport) !== 0) {
      // Throwing cooperates with Astro's dev HMR overlay (vs process.exit);
      // the message inlines the first ERROR findings.
      throw new Error(formatAuditThrowMessage(auditReport));
    }
  }
}
// All four setters follow the same pattern (ADR 0038 Revisions
// section): the chrome layer reads the accumulator directly, then
// pushes into each role's React store via a setter exported from
// @sophie/components. This keeps the components package
// Vite-protocol-agnostic.
//
// `__setFigureRegistry` receives the consumer-app prop directly.
// We could equivalently read `pedagogy.figureRegistry` (which the
// `indexAccumulator.setFigureRegistry(figureRegistry)` call two
// lines above populates) — both carry the same data. Passing the
// prop directly keeps the React-side wire explicit and avoids a
// redundant readonly trip. Per the two-tier model (decision #3),
// the EXTRACTOR never collects figure-registry data — it only
// walks in-MDX `<Figure>` USAGES; the REGISTRY of canonical
// figure metadata is consumer-owned in `content/figures.ts`.
//
// Key-insights and misconceptions have no React-side inline-ref
// component in v1 (no `<KeyInsightRef>` / `<MisconceptionRef>` ships),
// so no `__setKeyInsights` / `__setMisconceptions` setter exists yet.
// When those land (PR-C4+), they'll be added here in the same shape.
__setGlossaryDefinitions(pedagogy.definitions);
__setEquations(pedagogy.equations);
__setEquationCitations(pedagogy.equationCitations);
__setFigureRegistry(figureRegistry);
__setFigureUsages(pedagogy.figureUsages);
// objectives ships as a stub store for pattern uniformity — no v1
// React consumer (the `/library/objectives` page is server-rendered Astro
// that reads the accumulator directly); the setter + script tag
// anticipate future client-side consumers (PR 7 faceted search, a
// `<CourseObjectives client:visible>` widget, etc.) without
// rewiring TextbookLayout later.
__setObjectives(pedagogy.objectives);
// W1 + W2/D1 — hydrate the React-side sectionStore + unitStore +
// artifactStore so <ChapterRef chapter=…> (W2 prop rename per D3),
// <SpacedReview section=…> (W1 graduation), and future
// <LectureRef> / <ArtifactRef> components can read the consumer-supplied
// content-collection data without touching the Vite-only
// virtual:sophie/pedagogy-index. Per ADR 0001 (framework purity) +
// ADR 0038 Revisions.
__setSections(pedagogy.sections);
__setUnits(pedagogy.units);
__setArtifacts(pedagogy.artifacts);
// Course-info projection (2026-05-26) — hydrate the React-side
// courseSpecStore so chrome components in chapter MDX (<Points>,
// <OfficeHours>, etc.) can read structured spec data via the
// useCourseSpec() hook. Null spec (consumer hasn't authored
// course.sophie.yaml yet) → skip; the hook throws with a curated
// message if a chrome component is used regardless.
if (courseSpec) {
  __setCourseSpec(courseSpec);
}
// Serialize the same payloads into <script> tags so each role's
// client-side store can hydrate after React mount. Server-side module
// state doesn't survive to the wire, so without these script tags
// <GlossaryTerm> / <EquationRef> / <FigureRef> rerender as bare prose on
// hydration (empty client store wins). See
// packages/components/.../definitions-store.ts,
// packages/components/.../equations-store.ts,
// packages/components/.../figure-registry-store.ts,
// packages/components/.../figure-usages-store.ts.
//
// Escape `<` as `<` after JSON.stringify to prevent the
// HTML parser from terminating the <script> tag early on any
// `</script>` substring inside a payload body (realistic for
// AI-authored CS/web content per ADR 0030). The escape survives
// JSON.parse on the consumer side (< → <).
const pedagogyDefinitionsJson = JSON.stringify(pedagogy.definitions).replace(
  /</g,
  "\\u003c"
);
const pedagogyEquationsJson = JSON.stringify(pedagogy.equations).replace(
  /</g,
  "\\u003c"
);
const pedagogyEquationCitationsJson = JSON.stringify(
  pedagogy.equationCitations
).replace(/</g, "\\u003c");
const pedagogyFigureRegistryJson = JSON.stringify(figureRegistry).replace(
  /</g,
  "\\u003c"
);
const pedagogyFigureUsagesJson = JSON.stringify(pedagogy.figureUsages).replace(
  /</g,
  "\\u003c"
);
// Objectives payload — same escape treatment as the payloads above.
const pedagogyObjectivesJson = JSON.stringify(pedagogy.objectives).replace(
  /</g,
  "\\u003c"
);
// W1 + W2/D1 — payloads for the new sectionStore + unitStore + artifactStore.
const pedagogySectionsJson = JSON.stringify(pedagogy.sections).replace(
  /</g,
  "\\u003c"
);
const pedagogyUnitsJson = JSON.stringify(pedagogy.units).replace(
  /</g,
  "\\u003c"
);
const pedagogyArtifactsJson = JSON.stringify(pedagogy.artifacts).replace(
  /</g,
  "\\u003c"
);
// Course-info projection (2026-05-26) — courseSpec payload for
// client-side hydration of the courseSpecStore (used by
// useCourseSpec() in chrome components: <Points>, <OfficeHours>,
// etc.). Null spec → empty string → script tag emits `null`.
const courseSpecJson = courseSpec
  ? JSON.stringify(courseSpec).replace(/</g, "\\u003c")
  : "null";

// Detect empty named slots so the corresponding grid columns can
// collapse to 0 width — avoids wasted chrome in PR 1 where the sidebar
// and right column have no content yet. Once PRs 3 (sidebar nav) and
// 4 (in-page ToC) + 6 (margin asides) fill these slots, the columns
// expand naturally to their full widths.
const hasSidebarSlot = Astro.slots.has("sidebar");
const hasRightSlot = Astro.slots.has("right");

const collapsedVars = [
  hasSidebarSlot ? null : "--sophie-sidebar-w: 0",
  hasRightSlot ? null : "--sophie-right-w: 0",
]
  .filter((v): v is string => v !== null)
  .join(";");

/**
 * <TextbookLayout> — assembled book-theme layout shell.
 *
 * Composes <TopBar> + <Sidebar> + <ContentColumn> + <RightColumn>
 * inside a CSS Grid (`.sophie-shell`). Includes a boot script in
 * <head> that synchronously sets `data-sidebar` from localStorage
 * BEFORE paint, preventing FOUC on the user's preference.
 *
 * Usage (default):
 *
 *   <TextbookLayout>
 *     <slot />
 *   </TextbookLayout>
 *
 * For custom composition (top-bar content, sidebar contents, etc.),
 * import the named slots:
 *
 *   <TextbookLayout>
 *     <Fragment slot="topbar-extra"><MyToolbar /></Fragment>
 *     <Fragment slot="sidebar"><MyNav /></Fragment>
 *     <Fragment slot="right"><MyToc /></Fragment>
 *     <slot />
 *   </TextbookLayout>
 *
 * Per docs/plans/2026-05-12-layout-shell-foundation-design.md.
 */
---

{/* Boot script lives in <TextbookHead /> which the consumer puts inside <head>.
    See packages/astro/src/components/TextbookHead.astro for why
    (React's SSR mangles is:inline directives inside React islands per ADR 0027). */}

{/* Glossary-index payload for client-side hydration of <GlossaryTerm>'s
    definitions store. See packages/components/src/components/GlossaryTerm/definitions-store.ts
    for why this is needed alongside the server-side __setGlossaryDefinitions call. */}
<script
  is:inline
  id='sophie-pedagogy-definitions'
  type='application/json'
  set:html={pedagogyDefinitionsJson}
/>
{/* Equation-index payload for client-side hydration of <EquationRef>'s
    equations store. See packages/components/src/components/EquationRef/equations-store.ts
    for why this is needed alongside the server-side __setEquations call. */}
<script
  is:inline
  id='sophie-pedagogy-equations'
  type='application/json'
  set:html={pedagogyEquationsJson}
/>
{/* Sprint E — per-callsite <KeyEquation> citations payload. Hydrates
    the equation-citations store used by KeyEquation (margin "(C.N)"
    label) + EquationRef ("Eq. C.N" label). */}
<script
  is:inline
  id='sophie-pedagogy-equation-citations'
  type='application/json'
  set:html={pedagogyEquationCitationsJson}
/>
{/* Figure registry payload (two-tier figures, PR-C3 decision #3):
    canonical figure metadata supplied by the consumer app's
    content/figures.ts via the `figureRegistry` prop. Hydrates
    <FigureRef>'s figure-registry store after React mount. */}
<script
  is:inline
  id='sophie-figure-registry'
  type='application/json'
  set:html={pedagogyFigureRegistryJson}
/>
{/* Figure usages payload (two-tier figures, PR-C3 decision #3):
    per-chapter `<Figure>` occurrences harvested by the pedagogy
    extractor. Hydrates <FigureRef>'s figure-usages store after
    React mount. */}
<script
  is:inline
  id='sophie-pedagogy-figure-usages'
  type='application/json'
  set:html={pedagogyFigureUsagesJson}
/>
{/* Objectives collection payload (PR-C4):
    per-chapter learning objectives. v1 has no React consumer for the
    objectives store; ships alongside chapters/modules for pattern
    uniformity. Future consumers (PR 7 faceted search, a
    `<CourseObjectives client:visible>` widget) hydrate from here. */}
<script
  is:inline
  id='sophie-pedagogy-objectives'
  type='application/json'
  set:html={pedagogyObjectivesJson}
/>

{/* Wedge B-followup (W1) per ADR 0067 + design doc D1: SSR-emit the
    Section + Unit collections so the sectionStore + unitStore can
    auto-hydrate after React mount. Consumed by `<SpacedReview
    section=…>` (filters Units by section_id → collects chapter
    slugs → calls useInteractiveRangeMulti). */}
<script
  is:inline
  id='sophie-pedagogy-sections'
  type='application/json'
  set:html={pedagogySectionsJson}
/>
<script
  is:inline
  id='sophie-pedagogy-units'
  type='application/json'
  set:html={pedagogyUnitsJson}
/>
{/* W2/D1 (Path A) per ADR 0067 — SSR-emit the Artifact collection so
    the artifactStore can auto-hydrate after React mount. Consumed by
    `<ChapterRef chapter=…>` (W2 prop rename per D3): looks up the
    reading-artifact id, then walks to unitStore + sectionStore for
    hover-preview. */}
<script
  is:inline
  id='sophie-pedagogy-artifacts'
  type='application/json'
  set:html={pedagogyArtifactsJson}
/>
{/* Course-info projection (2026-05-26) — courseSpec payload for
    client-side hydration of the courseSpecStore. Used by chrome
    components in chapter MDX (<Points>, <OfficeHours>, etc.) via
    the useCourseSpec() hook. Always emitted; value is `null` when
    the consumer hasn't authored course.sophie.yaml yet (hook throws
    if a chrome component reads then). */}
<script
  is:inline
  id='sophie-course-spec'
  type='application/json'
  set:html={courseSpecJson}
/>

<div
  class='sophie-shell'
  id='sophie-sidebar-region'
  style={collapsedVars || undefined}
  data-sidebar-slot={hasSidebarSlot ? "filled" : "empty"}
  data-right-slot={hasRightSlot ? "filled" : "empty"}
  data-docked-asides={dockedAsides}
>
  <TopBar>
    <slot name='topbar-leading'>
      <SidebarToggle />
      <ChapterBreadcrumb
        moduleOrder={chapterContext?.moduleOrder}
        chapterNumber={chapterContext?.chapterNumber}
      />
    </slot>
    <slot name='topbar-trailing'>
      <ChapterStatusChip status={chapterContext?.status} />
      <SearchTrigger />
      {/* 2026-05-21 follow-up: ToC chevron moved INLINE with the
          "CONTENTS" header in the right column (MyST-style affordance
          in the margin). The TocSidebar's heading button now carries
          `data-sophie-toc-toggle`, so this topbar slot no longer
          renders a separate button. TocToggle.astro is retained for
          consumers that want a topbar toggle but is opt-in. */}
      <DisclosuresToggle />
      <ViewModeToggle />
      <ThemeToggle />
    </slot>
  </TopBar>
  <Sidebar>
    <slot name='sidebar' />
  </Sidebar>
  <ContentColumn>
    <slot />
  </ContentColumn>
  <RightColumn>
    <slot name='right' />
  </RightColumn>
</div>

<script>
  // PR 6: install the <Aside> docking lifecycle. Idempotent via a
  // window-level guard inside installAsidePositioning() — safe to
  // include in every textbook layout consumer. Per ADR 0032 this
  // runs as vanilla JS (not React). Listens to resize +
  // viewModePref change + MutationObserver on .sophie-content.
  import { installAsidePositioning } from "../lib/aside-positioning/install-positioning";
  installAsidePositioning();
</script>
