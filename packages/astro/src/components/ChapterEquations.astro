---
import type { EquationCitationEntry, EquationEntry } from "@sophie/core/schema";
import { indexAccumulator } from "../lib/pedagogy-index-extractor";
import BiographyRender from "./BiographyRender.astro";

const { equations, equationCitations } = indexAccumulator.asPedagogyIndex();

/**
 * `<ChapterEquations chapter="..." order="..." />` — Astro consumer
 * of the build-time pedagogy index per ADR 0060.
 *
 * Post-ADR-0060: citation-driven. Filters `equationCitations[]` by the
 * given chapter slug; joins each citation with the corresponding
 * `equations[]` registry entry (resolved by `refId`). Renders one
 * `<dl>` row per citation. `order="appearance"` (default) uses the
 * citation's per-chapter `number`; `order="alphabetical"` sorts by
 * the registry entry's `title`.
 *
 * Bodies are pre-rendered HTML embedded via `set:html` from the
 * biography. Pure Astro; no client JS.
 */
export interface Props {
  /** Chapter slug to filter equation citations by. */
  chapter: string;
  /** Sort strategy. Default appearance (citation order). */
  order?: "alphabetical" | "appearance";
  /** Optional heading rendered above the list. */
  heading?: string;
  /**
   * Heading level for the optional `heading` (2 | 3 | 4). Default 2.
   * Use 3 or 4 when the aggregator nests inside an existing section
   * with its own `<h2>` (per ADR 0038's nested-section pattern).
   */
  headingLevel?: 2 | 3 | 4;
}

const {
  chapter,
  order = "appearance",
  heading,
  headingLevel = 2,
} = Astro.props;

const HeadingTag = `h${headingLevel}` as const;

interface CitationWithEntry {
  citation: EquationCitationEntry;
  entry: EquationEntry;
}

const declarationById = new Map(equations.map((e) => [e.id, e]));
const citationsInChapter: CitationWithEntry[] = equationCitations
  .filter((c) => c.chapter === chapter)
  .map((c) => {
    const entry = declarationById.get(c.refId);
    return entry ? { citation: c, entry } : null;
  })
  .filter((x): x is CitationWithEntry => x !== null);

const sorted =
  order === "alphabetical"
    ? [...citationsInChapter].sort((a, b) =>
        a.entry.title.localeCompare(b.entry.title)
      )
    : [...citationsInChapter].sort((a, b) => a.citation.number - b.citation.number);
---

{heading && <HeadingTag class='sophie-chapter-equations__heading'>{heading}</HeadingTag>}
{
  sorted.length === 0 ? (
    <p class='sophie-chapter-equations__empty'>
      No key equations in this chapter yet.
    </p>
  ) : (
    <dl class='sophie-chapter-equations' data-sophie-chapter-equations=''>
      {sorted.map(({ citation, entry }) => (
        <Fragment>
          <dt id={citation.anchor} class='sophie-chapter-equations__term'>
            <span class='sophie-chapter-equations__number'>
              Eq. {citation.number}
            </span>
            <span class='sophie-chapter-equations__title'>{entry.title}</span>
          </dt>
          <dd class='sophie-chapter-equations__body'>
            {citation.framingHtml && <div set:html={citation.framingHtml} />}
            <BiographyRender biography={entry.biography} />
          </dd>
        </Fragment>
      ))}
    </dl>
  )
}
