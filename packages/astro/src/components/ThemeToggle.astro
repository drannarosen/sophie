---
import { Moon, Sun, SunMoon } from "../icons";

/**
 * <ThemeToggle> — accessible cycle button for the textbook theme.
 *
 * Cycles `system → light → dark → system`. State drives `data-theme`
 * on <html>, which `@sophie/theme` (per ADR 0005) maps to CSS custom
 * properties for the rendered theme.
 *
 * Pre-paint state is set by the boot script in <TextbookHead>; this
 * component wires the click handler and keeps the button's
 * aria-label + icon in sync with the stored preference.
 *
 * Per ADR 0032 (vanilla JS chrome state) — all interaction goes
 * through `themePref` (preferences/theme.ts), a `definePreference`
 * factory call. No React.
 *
 * Icons: Lucide `SunMoon` (system), `Sun` (light), `Moon` (dark) via
 * lucide-static — per the two-adapter icon convention introduced in
 * PR 5's design doc.
 */
---

<button
  type='button'
  class='sophie-theme-toggle'
  data-sophie-theme-toggle
  data-theme-pref='system'
  aria-label='Theme: system'
>
  {/* Three stacked icons; CSS shows one at a time based on data-theme-pref. */}
  <span
    class='sophie-theme-icon sophie-theme-icon-system'
    set:html={SunMoon}
  />
  <span class='sophie-theme-icon sophie-theme-icon-light' set:html={Sun} />
  <span class='sophie-theme-icon sophie-theme-icon-dark' set:html={Moon} />
</button>

<script>
  import {
    installSystemThemeListener,
    nextTheme,
    themePref,
    type ThemeStored,
  } from "../preferences";

  const LABELS: Record<ThemeStored, string> = {
    system: "Theme: system (auto)",
    light: "Theme: light",
    dark: "Theme: dark",
  };

  function syncUI(stored: ThemeStored): void {
    document
      .querySelectorAll<HTMLButtonElement>("[data-sophie-theme-toggle]")
      .forEach((btn) => {
        btn.setAttribute("data-theme-pref", stored);
        btn.setAttribute("aria-label", LABELS[stored]);
      });
  }

  syncUI(themePref.read());
  themePref.subscribe(syncUI);

  document
    .querySelectorAll<HTMLButtonElement>("[data-sophie-theme-toggle]")
    .forEach((btn) => {
      themePref.bindToggle(btn, nextTheme);
    });

  installSystemThemeListener();
</script>
