---
/**
 * <TextbookHead /> — renders the inline boot script that synchronously
 * sets `data-sidebar` on <html> from localStorage BEFORE paint, to
 * prevent FOUC of the user's sidebar preference.
 *
 * MUST live inside the consumer's <head>, NOT inside any React island
 * (per ADR 0027 — React's SSR mangles `is:inline` directives, dropping
 * the IIFE wrapper). Putting it in <head> keeps it Astro-pure.
 *
 * Consumer usage:
 *
 *   <html>
 *     <head>
 *       <TextbookHead />
 *     </head>
 *     <body>
 *       <TextbookLayout>...</TextbookLayout>
 *     </body>
 *   </html>
 *
 * Per docs/plans/2026-05-12-layout-shell-foundation-design.md.
 */
---

<script is:inline>
  (function () {
    // Mobile breakpoint matches packages/astro/src/styles/textbook-layout.css.
    var MOBILE_MAX = 768;
    function defaultForViewport() {
      // On mobile, the sidebar is a slide-over that obscures content.
      // Default it to "closed" so the chapter is reachable on first load.
      // Desktop default stays "open" (sidebar is part of the persistent grid).
      return window.innerWidth < MOBILE_MAX ? "closed" : "open";
    }
    try {
      var stored = localStorage.getItem("sophie:sidebar");
      // Honor an explicit user preference if set; otherwise fall back to
      // the viewport-aware default.
      var next =
        stored === "closed" ? "closed" :
        stored === "open"   ? "open"   :
        defaultForViewport();
      document.documentElement.setAttribute("data-sidebar", next);
    } catch (e) {
      document.documentElement.setAttribute(
        "data-sidebar",
        defaultForViewport(),
      );
    }
  })();
</script>
