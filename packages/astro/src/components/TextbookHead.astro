---
/**
 * <TextbookHead /> — emits one `is:inline` boot script per chrome
 * preference. Each script synchronously reads localStorage and sets
 * the matching `data-*` attribute on <html> BEFORE paint, preventing
 * FOUC of the user's persisted preferences.
 *
 * MUST live inside the consumer's <head>, NOT inside any React island
 * (per ADR 0033 — React's SSR mangles `is:inline` directives,
 * dropping the IIFE wrapper).
 *
 * Each new chrome preference in subsequent Bucket B PRs adds one
 * line here; preferences own their boot logic via `pref.bootScript()`
 * (per ADR 0032 vanilla-JS chrome state + ADR 0031 compound-component
 * isomorphism).
 *
 *   <html>
 *     <head>
 *       <TextbookHead />
 *     </head>
 *     <body>
 *       <TextbookLayout>...</TextbookLayout>
 *     </body>
 *   </html>
 */
import {
  disclosuresPref,
  rightSidebarPref,
  sidebarPref,
  themePref,
  viewModePref,
} from "../preferences";

// Sprint K (2026-05-21): both sidebars default to "closed" on all
// viewports — MyST-style "chapter is content; chrome opens on
// demand." The previous viewport-aware default (mobile-closed,
// desktop-open) is replaced by an unconditional "closed" — both
// sidebars now share the same UX convention across breakpoints.
// Users who open either sidebar persist that state via localStorage;
// the next reload remembers it.
const sidebarBoot = sidebarPref.bootScript();
const rightSidebarBoot = rightSidebarPref.bootScript();

// Theme default is "system" — resolved at boot via the
// resolveExpression on themePref (preferences/theme.ts), which
// inspects prefers-color-scheme. The runtime matchMedia change
// listener is installed by <ThemeToggle>.
const themeBoot = themePref.bootScript();

// View mode is the minimum-shape preference: stored value reflects
// verbatim onto data-view-mode. No viewport default, no resolve
// indirection. CSS handles the cross-state visual rules (sidebar +
// right column collapse when mode is focused|wide).
const viewModeBoot = viewModePref.bootScript();

// Disclosures pref: binary collapsed|expanded. Reflects onto
// data-disclosures; CSS forces <details>[open] on every disclosure-
// style Callout (deep-dive / the-more-you-know) when "expanded" so
// students with cognitive accommodations can see all depth content
// at once. Per 2026-05-19 architecture audit P2 #9.
const disclosuresBoot = disclosuresPref.bootScript();
---

<script is:inline set:html={sidebarBoot} />
<script is:inline set:html={rightSidebarBoot} />
<script is:inline set:html={themeBoot} />
<script is:inline set:html={viewModeBoot} />
<script is:inline set:html={disclosuresBoot} />
