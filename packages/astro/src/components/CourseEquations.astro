---
import type { EquationEntry } from "@sophie/core/schema";
import { indexAccumulator } from "../lib/pedagogy-index/accumulator";
import { withBase } from "../lib/with-base";
import BiographyRender from "./BiographyRender.astro";
import LibraryCollectionShell from "./LibraryCollectionShell.astro";

const { equations } = indexAccumulator.asPedagogyIndex();

/**
 * `<CourseEquations order="..." />` — Astro consumer that lists every
 * registry-declared equation across the whole textbook with a link
 * to the registry page at `/equations/<id>` (detail-route preserved
 * untouched per ADR 0070's W4a implementation note).
 *
 * Post-ADR-0060: declaration-driven (reads `equations[]` directly).
 * Default sort is alphabetical (per ADR 0038's course-side rule for
 * the registry-ecosystem aggregators). The pre-ADR-0060 chapter-order
 * default no longer applies — equations have no chapter on the
 * declaration; cross-chapter ordering would have to traverse
 * `equationCitations[]`, which `<ChapterEquations>` covers.
 *
 * Bodies render via `<BiographyRender>` from the registry-extracted
 * `biography` field (NOT `set:html` like glossary/key-insights — the
 * biography is a structured object, not pre-rendered HTML). Pure
 * Astro; no client JS.
 *
 * Wraps content in `<LibraryCollectionShell>` per W4c design D2 —
 * the shell owns the outer `<section aria-labelledby>` region
 * landmark + heading chrome + empty-state. Each `<dt>` emits
 * `data-section`/`data-unit`/`data-anchor` for Tier-2 filter
 * forward-compat per W4c design D8.
 *
 * Per W2: `data-section=""` and `data-unit=""` are empty because
 * `EquationEntry` is registry-sourced per ADR 0060 — it carries
 * NO `unit` field (registry MDX is not chapter-keyed) and NO
 * `section_id`. Cross-chapter joins live on `equationCitations[]`,
 * which `<ChapterEquations>` consumes; the Tier-2 filter UI can
 * join via the accumulator when it ships. `data-anchor` uses
 * `entry.id`, which IS the canonical anchor for the registry
 * detail route `/equations/<id>`.
 */
export interface Props {
  /** Sort strategy. Default alphabetical. */
  order?: "alphabetical";
  /** Optional heading rendered above the list. Defaults to "Key Equations". */
  heading?: string;
}

const { order = "alphabetical", heading = "Key Equations" } = Astro.props;

const sorted: EquationEntry[] = [...equations].sort((a, b) =>
  a.title.localeCompare(b.title)
);
// `order` parameter currently has one valid value; kept for forward-
// compatibility with a future tag-grouped or domain-grouped sort.
void order;
---

<LibraryCollectionShell
  collection='equations'
  heading={heading}
  emptyText='No key equations across the textbook yet.'
  isEmpty={sorted.length === 0}
>
  <dl class='sophie-course-equations' data-sophie-course-equations=''>
    {
      sorted.map((entry) => (
        <Fragment>
          <dt
            id={`eq-${entry.id}`}
            class='sophie-course-equations__term'
            data-section=''
            data-unit=''
            data-anchor={entry.id}
          >
            <span class='sophie-course-equations__title'>{entry.title}</span>
          </dt>
          <dd class='sophie-course-equations__body'>
            <BiographyRender biography={entry.biography} />
            <p class='sophie-course-equations__backlink'>
              registry entry at{" "}
              <a href={withBase(`/equations/${entry.id}`)}>
                <code>/equations/{entry.id}</code>
              </a>
            </p>
          </dd>
        </Fragment>
      ))
    }
  </dl>
</LibraryCollectionShell>
