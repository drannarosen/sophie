---
import type { EquationEntry } from "@sophie/core/schema";
import { indexAccumulator } from "../lib/pedagogy-index-extractor";
import BiographyRender from "./BiographyRender.astro";

const { equations } = indexAccumulator.asPedagogyIndex();

/**
 * `<CourseEquations order="..." />` — Astro consumer that lists every
 * registry-declared equation across the whole textbook with a link
 * to the registry page at `/equations/<id>`.
 *
 * Post-ADR-0060: declaration-driven (reads `equations[]` directly).
 * Default sort is alphabetical (per ADR 0038's course-side rule for
 * the registry-ecosystem aggregators). The pre-ADR-0060 chapter-order
 * default no longer applies — equations have no chapter on the
 * declaration; cross-chapter ordering would have to traverse
 * `equationCitations[]`, which `<ChapterEquations>` covers.
 *
 * Bodies are pre-rendered HTML embedded via `set:html` from the
 * biography. Pure Astro; no client JS.
 */
export interface Props {
  /** Sort strategy. Default alphabetical. */
  order?: "alphabetical";
  /** Optional heading rendered above the list. */
  heading?: string;
}

const { order = "alphabetical", heading } = Astro.props;

const sorted: EquationEntry[] = [...equations].sort((a, b) =>
  a.title.localeCompare(b.title)
);
// `order` parameter currently has one valid value; kept for forward-
// compatibility with a future tag-grouped or domain-grouped sort.
void order;
---

{heading && <h1 class='sophie-course-equations__heading'>{heading}</h1>}
{
  sorted.length === 0 ? (
    <p class='sophie-course-equations__empty'>
      No key equations across the textbook yet.
    </p>
  ) : (
    <dl class='sophie-course-equations' data-sophie-course-equations=''>
      {sorted.map((entry) => (
        <Fragment>
          <dt id={`eq-${entry.id}`} class='sophie-course-equations__term'>
            <span class='sophie-course-equations__title'>{entry.title}</span>
          </dt>
          <dd class='sophie-course-equations__body'>
            <BiographyRender biography={entry.biography} />
            <p class='sophie-course-equations__backlink'>
              registry entry at{" "}
              <a href={`/equations/${entry.id}`}>
                <code>/equations/{entry.id}</code>
              </a>
            </p>
          </dd>
        </Fragment>
      ))}
    </dl>
  )
}
