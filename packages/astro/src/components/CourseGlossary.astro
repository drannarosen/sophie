---
import { indexAccumulator } from "../lib/pedagogy-index/accumulator";
import { canonicalDefinitions } from "../lib/pedagogy-index/canonical-definitions";
import { withBase } from "../lib/with-base";
import LibraryCollectionShell from "./LibraryCollectionShell.astro";

const { definitions } = indexAccumulator.asPedagogyIndex();

/**
 * `<CourseGlossary heading="..." />` — Astro consumer that lists every
 * definition across the whole textbook, alphabetical. Each entry
 * back-links to its source chapter + anchor so a reader hitting an
 * unfamiliar term anywhere can return to the canonical treatment
 * (per overview decision #13).
 *
 * Per overview decision #12: course-glossary is alphabetical only
 * (chapter-glossary is the consumer that supports appearance order
 * via prop). Bodies render from pre-rendered HTML strings.
 *
 * Wraps content in `<LibraryCollectionShell>` per W4c design D2 —
 * the shell owns the outer `<section aria-labelledby>` region
 * landmark + heading chrome + empty-state. Each `<dt>` emits
 * `data-section`/`data-unit`/`data-anchor` for Tier-2 filter
 * forward-compat per W4c design D8. `data-section` is empty because
 * `DefinitionEntry` does not carry `section_id`; deriving from the
 * parent Unit would require accumulator changes that are not paid
 * for by a second consumer yet (W2). When the Tier-2 filter UI ships,
 * it can join via the accumulator.
 */
export interface Props {
  /** Optional heading rendered above the list. Defaults to "Glossary". */
  heading?: string;
}

const { heading = "Glossary" } = Astro.props;

// ADR 0086: a term may be defined in multiple chapters (cross-lecture
// reinforcement). The course glossary shows ONE entry per slug — the
// canonical one when a chapter opts in via `<Aside ... canonical>`, else
// the first-accumulated definition. See `canonicalDefinitions`.
const sorted = canonicalDefinitions(definitions).sort((a, b) =>
  a.term.localeCompare(b.term)
);
---

<LibraryCollectionShell
  collection='glossary'
  heading={heading}
  emptyText='No definitions across the textbook yet.'
  isEmpty={sorted.length === 0}
>
  <dl class='sophie-course-glossary' data-sophie-course-glossary=''>
    {
      sorted.map((entry) => (
        <Fragment>
          <dt
            id={`gloss-${entry.slug}`}
            class='sophie-course-glossary__term'
            data-section=''
            data-unit={entry.unit}
            data-anchor={entry.anchor}
          >
            {entry.term}
          </dt>
          <dd class='sophie-course-glossary__body'>
            <div set:html={entry.body} />
            <p class='sophie-course-glossary__backlink'>
              defined in{" "}
              <a href={withBase(`/units/${entry.unit}/reading#${entry.anchor}`)}>
                <code>{entry.unit}</code>
              </a>
            </p>
          </dd>
        </Fragment>
      ))
    }
  </dl>
</LibraryCollectionShell>
