---
import type { UnitViewKind } from "../lib/unit-views.ts";
import { withBase } from "../lib/with-base";

interface Props {
  unit: string;
  current: UnitViewKind;
  availableViews: ReadonlyArray<UnitViewKind>;
}

const { unit, current, availableViews } = Astro.props;

const labelMap: Record<UnitViewKind, string> = {
  reading: "Reading",
  slides: "Slides",
  practice: "Practice",
  solutions: "Solutions",
};

// Order locked: reading → slides → practice → solutions (read → see →
// do → check; solutions per ADR 0096). The helper already returns the
// views in this order, but re-filtering here guards against callers that
// pass an unordered set.
const orderedViews: ReadonlyArray<UnitViewKind> = [
  "reading",
  "slides",
  "practice",
  "solutions",
];
const tabs = orderedViews.filter((v) => availableViews.includes(v));
---

<nav class='sophie-unit-view-link-bar' aria-label='Unit views'>
  {
    tabs.map((v) => (
      <a
        href={withBase(`/units/${unit}/${v}`)}
        aria-current={v === current ? "page" : undefined}
        class:list={[
          "sophie-unit-view-link-bar__tab",
          v === current && "sophie-unit-view-link-bar__tab--active",
        ]}
      >
        {labelMap[v]}
      </a>
    ))
  }
</nav>
