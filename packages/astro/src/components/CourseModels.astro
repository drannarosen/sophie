---
import CourseOMIRollup from "./_shared/CourseOMIRollup.astro";

/**
 * `<CourseModels heading="..." />` — Thin adapter for the `model`
 * slot rollup. Delegates to the shared `CourseOMIRollup` factory
 * (post-W4c PR 4 M1 DRY extraction; pre-extraction this file
 * carried the full rendering — see git blame for the original shape).
 * Behavior is bit-identical to the pre-extraction component.
 */
export interface Props {
  /** Optional heading rendered above the list. Defaults to "Models". */
  heading?: string;
}
const { heading } = Astro.props;
---
<CourseOMIRollup role='model' heading={heading} />
