---
import type {
  EquationCitationEntry,
  EquationEntry,
} from "@sophie/core/schema";
import katex from "katex";
import BiographyRender from "./BiographyRender.astro";
import LibraryCollectionShell from "./LibraryCollectionShell.astro";

/**
 * `<EquationSpecContent>` — per-entry Spec content for the route at
 * `/library/equations/<id>/` (W4c Batch 7 Task 7.1). First of five
 * W4a-era Spec content components (Tasks 7.1-7.5); the route file is
 * a thin getStaticPaths + layout-wiring shell.
 *
 * Renders, per W4c design D3:
 *   1. KaTeX-rendered LaTeX (display mode; HTML output safe — registry
 *      source is Zod-validated, KaTeX `throwOnError: false` produces
 *      escaped error spans not raw HTML),
 *   2. Epistemic-role label ("Role: Model") per ADR 0058 §2 —
 *      equations are role `"model"` in the eight-role taxonomy,
 *   3. `<BiographyRender>` (Observable / Assumption / Units /
 *      BreaksWhen / CommonMisuse) when biography is present
 *      (per-equation opt-in per ADR 0046 §R8),
 *   4. Cross-references — the list of Units that cite this equation,
 *      derived from the `citations` prop (filtered `equationCitations`
 *      from `indexAccumulator` at the route level). The Unit slug
 *      links to `/sections/<unit>/` is deferred to Tier-2 (W2 — the
 *      link shape isn't locked yet); v1 lists slugs as `<code>` runs
 *      with the citation anchor.
 *
 * Wraps content in `<LibraryCollectionShell collection="equation-spec"
 * heading={equation.title}>` — per-entry use of the shell (the shell's
 * primitives-and-slots split fits per-entry as cleanly as per-room).
 * The shell owns the `<section aria-labelledby>` landmark + the H1.
 *
 * Pure Astro; no client JS. KaTeX renders server-side via
 * `katex.renderToString` (the same approach `<KeyEquation>`'s
 * `InlineTex` helper uses inside `@sophie/components`).
 *
 * Why this component is split from the route:
 * Container API (Batch 3b infra) cannot drive full-page Astro routes
 * (no layouts, no `getStaticPaths`, no integration globals); see
 * `container-axe.ts` JSDoc §"What this helper does NOT cover".
 * Splitting the Spec content out makes the rendered shape unit-axe-
 * testable. Full-page axe coverage of Spec routes lands via Batch 3c's
 * Playwright harness.
 */
export interface Props {
  equation: EquationEntry;
  citations: ReadonlyArray<EquationCitationEntry>;
}

const { equation, citations } = Astro.props;

const texHtml = katex.renderToString(equation.tex, {
  displayMode: true,
  throwOnError: false,
  output: "html",
});

const citingUnits = Array.from(new Set(citations.map((c) => c.unit)));
const crossrefsHeadingId = `sophie-equation-spec-${equation.id}-crossrefs`;
---

<LibraryCollectionShell
  collection='equation-spec'
  heading={equation.title}
  emptyText=''
  isEmpty={false}
>
  <div
    class='sophie-equation-spec'
    data-sophie-equation-spec={equation.id}
  >
    <p class='sophie-equation-spec__role' data-epistemic-role='model'>
      <span class='sophie-equation-spec__role-label'>Role:</span>{" "}
      <span class='sophie-equation-spec__role-value'>Model</span>
    </p>

    <div class='sophie-equation-spec__tex'>
      {/* biome-ignore lint/security/noDangerouslySetInnerHtml: tex rendered by katex from registry-validated source; KaTeX includes hidden MathML for AT. */}
      <Fragment set:html={texHtml} />
    </div>

    {equation.biography && <BiographyRender biography={equation.biography} />}

    {citingUnits.length > 0 && (
      <section
        class='sophie-equation-spec__crossrefs'
        aria-labelledby={crossrefsHeadingId}
      >
        <h2
          id={crossrefsHeadingId}
          class='sophie-equation-spec__crossrefs-heading'
        >
          Referenced in
        </h2>
        <ul class='sophie-equation-spec__crossrefs-list'>
          {citingUnits.map((unit) => (
            <li class='sophie-equation-spec__crossrefs-item'>
              <code>{unit}</code>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</LibraryCollectionShell>
