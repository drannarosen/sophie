  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/components/_shared dist/styles dist/routes && cp src/components/*.astro dist/components/ && cp src/components/_shared/*.astro dist/components/_shared/ && cp src/styles/*.css dist/styles/ && cp src/routes/*.astro dist/routes/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "esbuild": "^0.27.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "vite": "^7.3.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.5",
    "@sophie/components": "workspace:*",
