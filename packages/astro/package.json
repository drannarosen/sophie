{
  "name": "@sophie/astro",
  "version": "0.0.0",
  "description": "Sophie's single Astro coupling point: MDX + React 19 + theme injection + makeStaticComponents factory + SophieChapter CSS-shell wrapper.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/SophieChapter.d.ts",
      "import": "./dist/client/SophieChapter.js"
    },
    "./components/TextbookLayout.astro": "./dist/components/TextbookLayout.astro",
    "./components/TextbookHead.astro": "./dist/components/TextbookHead.astro",
    "./components/TopBar.astro": "./dist/components/TopBar.astro",
    "./components/Sidebar.astro": "./dist/components/Sidebar.astro",
    "./components/ContentColumn.astro": "./dist/components/ContentColumn.astro",
    "./components/RightColumn.astro": "./dist/components/RightColumn.astro",
    "./components/ModuleNav.astro": "./dist/components/ModuleNav.astro",
    "./components/SidebarToggle.astro": "./dist/components/SidebarToggle.astro",
    "./components/ThemeToggle.astro": "./dist/components/ThemeToggle.astro",
    "./components/TocDrawer.astro": "./dist/components/TocDrawer.astro",
    "./components/TocSidebar.astro": "./dist/components/TocSidebar.astro",
    "./styles/textbook-layout.css": "./dist/styles/textbook-layout.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/components dist/styles && cp src/components/*.astro dist/components/ && cp src/styles/*.css dist/styles/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "esbuild": "^0.27.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@sophie/components": "workspace:*",
    "@sophie/core": "workspace:*",
    "@sophie/theme": "workspace:*",
    "katex": "^0.16.45",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "astro": "^6.3.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
