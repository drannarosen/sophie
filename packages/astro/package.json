{
  "name": "@sophie/astro",
  "version": "0.0.0",
  "description": "Sophie's single Astro coupling point: MDX + React 19 + theme injection + makeStaticComponents factory + SophieChapter CSS-shell wrapper.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/SophieChapter.d.ts",
      "import": "./dist/client/SophieChapter.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "esbuild": "^0.27.0",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@sophie/components": "workspace:*",
    "@sophie/core": "workspace:*",
    "@sophie/theme": "workspace:*",
    "katex": "^0.16.45",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "astro": "^6.3.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
