# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
.turbo/
.astro/
*.tsbuildinfo
storybook-static/

# Storybook test-runner diff output (per-failure visual diffs from
# jest-image-snapshot). Baselines under __snapshots__/ ARE committed —
# this is just the diff PNGs emitted on failure.
__diff_output__/

# test outputs
coverage/
playwright-report/
test-results/
.playwright-mcp/
.vitest-cache/

# transient screenshots from interactive verification
step-7-acceptance.png
*.acceptance.png
# Ad-hoc visual-polish scratch dir for Playwright MCP screenshot
# captures during interactive review/iteration. Keepers move into
# docs/reviews/assets/<date>/ (committed) or a package's __snapshots__/
# (Storybook VR). This dir is never tracked.
.review-temp/
# Visual-polish + verify-pass debug screenshots accumulated during
# sprint iterations (Playwright MCP `browser_take_screenshot` output,
# manual saves, etc). Root-level PNGs are NEVER committed; PNGs that
# belong to the codebase live under their package's `figures/`,
# `__snapshots__/`, or `public/` directories — those scoped paths are
# unaffected by this root-only `/*.png` rule.
/*.png

# MyST docs build output (top-level logs and docs/website/_build/ both)
_build/

# Stray myst.yml at the repo ROOT only (created by accidentally running
# `mystmd init` from /Users/anna/Teaching/sophie/ instead of
# docs/website/). The leading slash anchors this to the repo root —
# docs/website/myst.yml (the real, populated docs-site config) is NOT
# matched and stays tracked.
/myst.yml

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# env / secrets
.env
.env.local
.env.*.local

# Claude Code local settings (user-specific permissions, task
# scheduler state, agent worktree metadata, credentials, etc.).
# Blanket-ignore the whole directory so future Claude additions
# don't reappear as untracked.
.claude/

# Git worktrees for isolated feature branches (per
# superpowers:using-git-worktrees). Each subdirectory is a separate
# checkout sharing this repo's .git/ — never commit their contents.
.worktrees/
