{
  "name": "sophie",
  "version": "0.0.0",
  "private": true,
  "description": "Schema-driven, AI-authorable platform for interactive scientific textbooks, course websites, slide decks, and LMS exports.",
  "license": "AGPL-3.0-or-later",
  "author": "Anna Rosen",
  "homepage": "https://github.com/drannarosen/sophie",
  "repository": {
    "type": "git",
    "url": "https://github.com/drannarosen/sophie.git"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.56.0",
    "turbo": "2.9.12",
    "typescript": "6.0.3",
    "tsx": "4.21.0"
  }
}
